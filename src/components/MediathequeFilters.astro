---
// MediathequeFilters.astro
// Sistema de búsqueda visual por "Tipo de Nutriente"
---
<div class="mediatheque-filters glass-panel">
  <div class="filter-header">
    <div class="icon-scan">📡</div>
    <h3>Filtros de Nutrición Intelectual</h3>
  </div>
  
  <div class="filter-buttons">
    <button class="filter-btn active" data-type="all">
      <span class="btn-icon">🌐</span>
      <span class="btn-text">Todos los Nutrientes</span>
    </button>
    <button class="filter-btn" data-type="text">
      <span class="btn-icon">📝</span>
      <span class="btn-text">Textos Científicos</span>
    </button>
    <button class="filter-btn" data-type="image">
      <span class="btn-icon">🖼️</span>
      <span class="btn-text">Imágenes del Atelier</span>
    </button>
    <button class="filter-btn" data-type="sound">
      <span class="btn-icon">🎧</span>
      <span class="btn-text">Podcasts y Sonido</span>
    </button>
    <button class="filter-btn" data-type="data">
      <span class="btn-icon">📊</span>
      <span class="btn-text">Datos / Scripts</span>
    </button>
  </div>
</div>

<style>
.mediatheque-filters {
  margin: 3rem 0;
  padding: 2rem;
  border: 1px solid var(--color-glass-border);
}

.filter-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 2rem;
}

.icon-scan {
  font-size: 1.5rem;
  filter: drop-shadow(0 0 8px var(--color-digital-cyan));
}

h3 {
  margin: 0;
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--color-digital-cyan);
  text-transform: uppercase;
  letter-spacing: 1px;
}

.filter-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
}

.filter-btn {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--color-glass-border);
  color: rgba(255, 255, 255, 0.7);
  padding: 0.75rem 1.5rem;
  border-radius: 40px;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-sans);
  font-weight: 500;
  font-size: 0.9rem;
}

.filter-btn:hover {
  background: rgba(255, 255, 255, 0.1);
  border-color: var(--color-digital-cyan);
  color: white;
  transform: translateY(-2px);
  box-shadow: 0 4px 15px rgba(0, 242, 255, 0.1);
}

.filter-btn.active {
  background: var(--color-neural-red);
  color: white;
  border-color: var(--color-neural-red);
  box-shadow: 0 0 20px var(--color-neural-red-glow);
}

.btn-icon {
  font-size: 1.1rem;
}

.btn-text {
  letter-spacing: 0.5px;
}
</style>

<script>
// Lógica de filtrado visual
document.addEventListener('DOMContentLoaded', () => {
  const buttons = document.querySelectorAll('.filter-btn');
  // Se asume que el contenido de la Mediateca tendrá atributos data-nutrient-type
  
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      const type = btn.getAttribute('data-type');
      const items = document.querySelectorAll('.nutrient-item');
      
      items.forEach((item: any) => {
        if (type === 'all' || item.getAttribute('data-nutrient-type') === type) {
          item.style.display = 'block';
        } else {
          item.style.display = 'none';
        }
      });
    });
  });
});
</script>
