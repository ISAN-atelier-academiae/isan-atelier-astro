---
// VitruvianExplorer.astro
// Unified Sovereign File Explorer & Digital Brain Hologram
// Calibrated under the ISAN-2026 Academic Standard
---
<!-- Adytum Academiae Modal -->
<div id="adytum-academiae-modal" class="adytum-overlay fixed inset-0 z-[9999] flex flex-col items-center justify-center bg-black/95 backdrop-blur-xl transition-all duration-1000 ease-in-out">
  <div class="adytum-content border border-cyan-500/20 p-12 bg-[#020307]/80 rounded-sm shadow-[0_0_50px_rgba(0,0,0,1)] text-center max-w-2xl transform transition-transform duration-1000">
    <h1 class="text-cyan-400 font-serif text-3xl mb-4 tracking-widest uppercase" style="text-shadow: 0 0 10px rgba(0,242,255,0.5);">ADYTUM ACADEMIAE</h1>
    <div class="flex justify-center mb-6 text-cyan-500/50 drop-shadow-[0_0_8px_rgba(0,242,255,0.4)]">
      <svg width="40" height="40" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2">
        <polygon points="10,10 90,10 50,90" />
      </svg>
    </div>
    <div class="flex flex-col md:flex-row justify-center items-center gap-10 mb-8 w-full max-w-2xl mx-auto">
      <!-- Ancient Wind Face -->
      <div class="relative w-40 h-32 md:w-56 md:h-40 rounded-[40%] overflow-hidden border-none shadow-[0_0_25px_rgba(193,154,107,0.15)] flex-shrink-0" style="background: radial-gradient(circle, rgba(193,154,107,0.1) 0%, transparent 80%);">
        <img src="/images/CONSIDERA_SUSURRUM_V2.png" alt="Considera Susurrum" class="w-full h-full object-cover opacity-85 mix-blend-screen" />
      </div>

      <!-- Rosa de los Vientos Antigua (Portolan Style) -->
      <div class="relative w-48 h-48 md:w-56 md:h-56 opacity-90 flex-shrink-0" style="filter: drop-shadow(0 0 15px rgba(193,154,107,0.3)); color: #c19a6b;">
        <svg viewBox="0 0 200 200" class="w-full h-full animate-[spin_120s_linear_infinite]" stroke="currentColor" fill="none">
          <!-- Outer Rings -->
          <circle cx="100" cy="100" r="95" stroke-width="0.5"/>
          <circle cx="100" cy="100" r="92" stroke-width="2"/>
          <circle cx="100" cy="100" r="88" stroke-width="0.5"/>
          <circle cx="100" cy="100" r="84" stroke-width="0.5" stroke-dasharray="2 4"/>

          <!-- Ancient Navigator's Compass Star -->
          <g stroke="none">
            <!-- North Pointer (Often more ornate in ancient maps) -->
            <path d="M100 15 L108 92 L100 100 Z" fill="rgba(193,154,107,0.9)"/>
            <path d="M100 15 L92 92 L100 100 Z" fill="rgba(193,154,107,0.3)"/>
            
            <!-- East Pointer -->
            <path d="M185 100 L108 108 L100 100 Z" fill="rgba(193,154,107,0.9)"/>
            <path d="M185 100 L108 92 L100 100 Z" fill="rgba(193,154,107,0.3)"/>

            <!-- South Pointer -->
            <path d="M100 185 L92 108 L100 100 Z" fill="rgba(193,154,107,0.9)"/>
            <path d="M100 185 L108 108 L100 100 Z" fill="rgba(193,154,107,0.3)"/>

            <!-- West Pointer -->
            <path d="M15 100 L92 92 L100 100 Z" fill="rgba(193,154,107,0.9)"/>
            <path d="M15 100 L92 108 L100 100 Z" fill="rgba(193,154,107,0.3)"/>

            <!-- Secondary Stars (NE, SE, SW, NW) -->
            <g fill="rgba(193,154,107,0.5)">
              <path d="M160 40 L112 88 L100 100 Z"/>
              <path d="M160 40 L112 112 L100 100 Z" opacity="0.4"/>
              
              <path d="M160 160 L112 112 L100 100 Z"/>
              <path d="M160 160 L88 112 L100 100 Z" opacity="0.4"/>

              <path d="M40 160 L88 112 L100 100 Z"/>
              <path d="M40 160 L88 88 L100 100 Z" opacity="0.4"/>

              <path d="M40 40 L88 88 L100 100 Z"/>
              <path d="M40 40 L112 88 L100 100 Z" opacity="0.4"/>
            </g>
            
            <!-- Tertiary Stars (16-point) -->
            <g fill="rgba(193,154,107,0.3)" opacity="0.7">
              <path d="M130 20 L104 90 L100 100 Z"/><path d="M70 20 L96 90 L100 100 Z"/>
              <path d="M180 70 L110 96 L100 100 Z"/><path d="M180 130 L110 104 L100 100 Z"/>
              <path d="M130 180 L104 110 L100 100 Z"/><path d="M70 180 L96 110 L100 100 Z"/>
              <path d="M20 130 L90 104 L100 100 Z"/><path d="M20 70 L90 96 L100 100 Z"/>
            </g>
          </g>

          <!-- Old Latin Labels (Septentrio, Oriens, Meridies, Occidens) -->
          <g class="font-serif text-sm font-bold" fill="currentColor" stroke="none" text-anchor="middle" dominant-baseline="central">
            <text x="100" y="26">S</text>
            <text x="174" y="100">O</text>
            <text x="100" y="174">M</text>
            <text x="26" y="100">O</text>
          </g>

          <!-- Center Details -->
          <circle cx="100" cy="100" r="12" fill="none" stroke="rgba(193,154,107,0.8)" stroke-width="1"/>
          <circle cx="100" cy="100" r="6" fill="rgba(193,154,107,1)" stroke="none"/>
          <circle cx="100" cy="100" r="2" fill="#000" stroke="none"/>
        </svg>
      </div>
    </div>
    <button id="intrare-consolam-btn" class="mt-4 px-8 py-3 border border-cyan-400/50 text-cyan-300 font-mono text-xs tracking-widest hover:bg-cyan-500/10 hover:text-white hover:border-cyan-300 hover:shadow-[0_0_25px_rgba(0,242,255,0.4)] transition-all duration-300 cursor-pointer">
      [ INTRARE IN CONSOLAM ]
    </button>
  </div>
</div>

<!-- The Barra Vitruvio Scroll Sync Bar (Fixed on the right edge) -->
<div id="barra-vitruvio" class="barra-vitruvio"></div>

<!-- Floating Vitruvian Theme Sensor (Floating next to the scrollbar) -->
<div id="vitruvio-sensor-badge" class="vitruvio-sensor-badge">
  <span class="sensor-icon" id="sensor-icon">🏺</span>
  <span class="sensor-theme" id="sensor-theme">EL ORIGEN HERMÉTICO</span>
  
  <!-- Hover Expanded 10-Theme Palette Widget -->
  <div class="vitruvio-palette-widget glass-panel">
    <div class="palette-widget-header">
      <span>🎨 PALETA COGNITIVA VITRUVIANA (ISAN-2026)</span>
    </div>
    <div class="palette-themes-grid">
      <div class="p-theme-row" style="--t-color: #ef4444">
        <span class="p-theme-bullet">🔴</span>
        <div class="p-theme-info">
          <strong>EL ORIGEN HERMÉTICO (0%-10%)</strong>
          <p>Soberanía y cimientos constitutivos de la fundación.</p>
        </div>
      </div>
      <div class="p-theme-row" style="--t-color: #ec4899">
        <span class="p-theme-bullet">🎭</span>
        <div class="p-theme-info">
          <strong>LA EXPRESIÓN POÉTICA (10%-20%)</strong>
          <p>Estética superior y fluidez de bellas artes.</p>
        </div>
      </div>
      <div class="p-theme-row" style="--t-color: #14b8a6">
        <span class="p-theme-bullet">🎓</span>
        <div class="p-theme-info">
          <strong>LA ACADEMIA ACTIVA (20%-30%)</strong>
          <p>Pedagogía interactiva y formación de campus.</p>
        </div>
      </div>
      <div class="p-theme-row" style="--t-color: #f59e0b">
        <span class="p-theme-bullet">📜</span>
        <div class="p-theme-info">
          <strong>LA NARRATIVA HISTÓRICA (30%-40%)</strong>
          <p>Bitácora de desarrollo y diario cronológico.</p>
        </div>
      </div>
      <div class="p-theme-row" style="--t-color: #6366f1">
        <span class="p-theme-bullet">⚖️</span>
        <div class="p-theme-info">
          <strong>LA CURIA DEL CAMBIO (40%-50%)</strong>
          <p>Ecosistema de transacciones y ledger IDX.</p>
        </div>
      </div>
      <div class="p-theme-row" style="--t-color: #a855f7">
        <span class="p-theme-bullet">🐍</span>
        <div class="p-theme-info">
          <strong>EL TEMPLO DE LA SERPIENTE (50%-60%)</strong>
          <p>Hermetismo, geometría sagrada y proporciones.</p>
        </div>
      </div>
      <div class="p-theme-row" style="--t-color: #10b981">
        <span class="p-theme-bullet">📐</span>
        <div class="p-theme-info">
          <strong>LA MÉTRICA CONSTRUCTIVA (60%-70%)</strong>
          <p>Metrología de Giza y control físico axial.</p>
        </div>
      </div>
      <div class="p-theme-row" style="--t-color: #6b7280">
        <span class="p-theme-bullet">👁️</span>
        <div class="p-theme-info">
          <strong>EL SILENCIO CRIPTOGRÁFICO (70%-80%)</strong>
          <p>Integridad local-first y firmas SHA-256.</p>
        </div>
      </div>
      <div class="p-theme-row" style="--t-color: #06b6d4">
        <span class="p-theme-bullet">💻</span>
        <div class="p-theme-info">
          <strong>LA COMPUTACIÓN SOBERANA (80%-90%)</strong>
          <p>Código abierto, bunkers cloud y estabilidad.</p>
        </div>
      </div>
      <div class="p-theme-row" style="--t-color: #f97316">
        <span class="p-theme-bullet">🛡️</span>
        <div class="p-theme-info">
          <strong>EL MANIFIESTO OPERATIVO (90%-100%)</strong>
          <p>Independencia digital y leyes corporativas.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Custom Page Header: Left Title / Right D3 Hologram -->
<div class="custom-portal-header glass-panel console-veiled transition-all duration-1000">
  <div class="header-text-block">
    <span class="portal-badge-top">🛡️ SECURE SOVEREIGN NODE</span>
    <h1 class="portal-main-title">ISAN ATELIER ACADEMIAE C.A.</h1>
    <h2 class="portal-sub-title" style="font-size: 0.85rem; color: #a1a1aa; font-style: italic; margin-top: -0.2rem; margin-bottom: 1.5rem; letter-spacing: 1px;">Societas academica independens in scientiis humanitatis.</h2>
    <div class="portal-meta-subtext-container mt-5 p-4 bg-black/60 border-l-2 border-cyan-500/80 shadow-[inset_10px_0_30px_rgba(0,242,255,0.05),0_0_15px_rgba(0,0,0,0.8)] w-fit rounded-r-sm backdrop-blur-sm transition-all hover:border-cyan-400 hover:shadow-[inset_10px_0_30px_rgba(0,242,255,0.1),0_0_15px_rgba(0,242,255,0.1)]">
      <div id="portal-axial-clock" class="portal-tagline text-emerald-400 drop-shadow-[0_0_5px_rgba(16,185,129,0.5)] font-mono text-xs tracking-wider mb-2">
        [ CICLO: 2026 // EJE-TEMPORAL: UTC-4 // HORA-AXIAL: --:--:-- // STATUS: SINC ]
      </div>
      <div id="portal-axioma" class="portal-axioma-subtext text-cyan-300/80 font-mono text-xs mb-3 italic">
        // Sinapsis del Atelier: El arte y la técnica unificados en el búnker.
      </div>
      <div id="portal-node-counter" class="portal-node-counter-subtext text-[#c19a6b] font-mono text-xs drop-shadow-[0_0_3px_rgba(193,154,107,0.5)] tracking-widest border-t border-white/5 pt-2">
        🔒 BÓVEDA OBSIDIAN: SINC // 762 NODOS ACTIVOS
      </div>
    </div>
  </div>
  
  <div class="header-hologram-block relative group z-50">
    <div id="hologram-trigger-frame" class="hologram-lens-frame cursor-pointer transition-all duration-500 group-hover:shadow-[0_0_25px_rgba(0,242,255,0.3)] group-hover:border-cyan-500/60 relative">
      <button id="close-hologram-btn" class="absolute top-4 right-4 text-cyan-400 text-3xl hidden opacity-0 transition-opacity hover:text-white drop-shadow-[0_0_5px_rgba(0,242,255,0.8)] z-50">&times;</button>
      <div class="hologram-title-overlay group-hover:text-cyan-400 group-hover:drop-shadow-[0_0_5px_rgba(0,242,255,0.8)] transition-all">🔮 HOLOGRAMA DE LA SERPIENTE</div>
      <div id="header-hologram-container" class="header-hologram-container"></div>
    </div>
    
    <!-- Hologram Hover Widget (Moved outside overflow:hidden) -->
    <div id="hologram-hover-widget" class="absolute top-1/2 right-full mr-4 w-56 p-4 bg-[#050505]/95 border border-cyan-500/50 opacity-0 pointer-events-none group-hover:opacity-100 transition-all duration-500 shadow-[0_0_20px_rgba(0,242,255,0.2)] rounded-sm transform translate-x-4 group-hover:translate-x-0 z-[100] backdrop-blur-md">
      <h4 class="text-cyan-400 text-[0.65rem] tracking-widest border-b border-cyan-500/30 pb-1 mb-2 font-mono uppercase" style="text-shadow: 0 0 5px rgba(0,242,255,0.5);">MODO INMERSIVO</h4>
      <p class="text-gray-300 text-[0.6rem] leading-relaxed font-serif italic mb-3">Haz clic para desplegar la ventana ortogonal y navegar libremente por los confines de la red neuronal.</p>
      <div class="text-[0.55rem] text-emerald-400 tracking-widest font-mono uppercase text-right">>> INICIAR ENLACE</div>
    </div>
  </div>
</div>

<div class="vitruvian-explorer-wrapper glass-panel console-veiled transition-all duration-1000 delay-300">
  <!-- Window Header Bar -->
  <div class="explorer-window-header">
    <div class="mac-buttons">
      <span class="mac-dot red"></span>
      <span class="mac-dot yellow"></span>
      <span class="mac-dot green"></span>
    </div>
    <div class="explorer-window-title">
      <span>🌐 ISAN ACADEMIA CENTRALIS // EXPLORER v2026 // SECURE CONSOLE</span>
    </div>
    <div class="system-status">
      <span class="status-indicator-dot"></span> SECURE SHELL ACTIVE
    </div>
  </div>

  <!-- Global Health Monitor Bar (HUD) -->
  <div class="global-telemetry-bar">
    <div class="hud-item hud-pulse-item">
      <span class="hud-icon">🏛️</span>
      <span class="hud-label">ECOSISTEMA:</span>
      <span class="hud-value text-green">100% ÓPTIMO</span>
      <span class="hud-pulse"></span>
    </div>
    <div class="hud-item">
      <span class="hud-icon">🛡️</span>
      <span class="hud-label">SEGURIDAD:</span>
      <span class="hud-value text-gold">CIFRADO ACTIVO</span>
    </div>
    <div class="hud-item">
      <span class="hud-icon">⚖️</span>
      <span class="hud-label">FLUJO DE INFO:</span>
      <span class="hud-value text-cyan">100% ACCESIBLE</span>
    </div>
  </div>

  <div class="explorer-grid">
    <!-- Panel 1: Sidebar Directory Tree -->
    <div class="explorer-sidebar">
      <div class="sidebar-title">🧭 EXPLORADOR AXIAL DE CÓDICES</div>
      <ul class="directory-tree">
        <!-- Root Folder: Quartz -->
        <li class="directory-folder" data-folder="quartz">
          <span class="folder-name">🏺 Arcano Sagrado de Quartz</span>
          <ul class="folder-files">
            <li class="file-item active" data-node="biblioteca">
              <span class="file-icon">🏛️</span> Biblioteca Alejandrina
            </li>
            <li class="file-item" data-node="bitacora">
              <span class="file-icon">📜</span> Anales Académicos
            </li>
            <li class="file-item" data-node="curia_cambii">
              <span class="file-icon">⚖️</span> Curia Cambii (Tabla)
            </li>
            <li class="file-item" data-node="dossier">
              <span class="file-icon">🖋️</span> Codex Vitruvianus
            </li>
            <li class="file-item" data-node="isan_atelier">
              <span class="file-icon">🛡️</span> Escudo del Atelier
            </li>
            <li class="file-item" data-node="sendero_serpiente">
              <span class="file-icon">🐍</span> Sendero de la Serpiente
            </li>
            <li class="file-item" data-node="convergencia">
              <span class="file-icon">📐</span> Ley de la Convergencia
            </li>
            <li class="file-item" data-node="cursos_web">
              <span class="file-icon">🎓</span> Mysterium Web (Cursos)
            </li>
          </ul>
        </li>

        <!-- Root Folder: Bunker -->
        <li class="directory-folder" data-folder="bunker">
          <span class="folder-name">🛡️ Sanctum Soberano</span>
          <ul class="folder-files">
            <li class="file-item" data-node="bunker">
              <span class="file-icon">🔑</span> Clave del Búnker
            </li>
            <li class="file-item" data-node="manifiesto">
              <span class="file-icon">📜</span> Tablas del Manifiesto
            </li>
            <li class="file-item" data-node="reglamento_adn">
              <span class="file-icon">🧬</span> Reglamento ADN
            </li>
            <li class="file-item" data-node="reglamento_completo">
              <span class="file-icon">📜</span> Ley Suprema (Reglamento)
            </li>
          </ul>
        </li>

        <!-- Root Folder: Reports -->
        <li class="directory-folder" data-folder="reports">
          <span class="folder-name">⚖️ Codex Metrología</span>
          <ul class="folder-files">
            <li class="file-item" data-node="informes">
              <span class="file-icon">📊</span> Tablilla de Informes
            </li>
            <li class="file-item" data-node="inf_0001">
              <span class="file-icon">📈</span> Informe 0001 (POUS)
            </li>
            <li class="file-item" data-node="inf_0002">
              <span class="file-icon">🧠</span> Informe 0002 (Obsidian)
            </li>
            <li class="file-item" data-node="inf_0006">
              <span class="file-icon">🔮</span> Oráculo de Delfos
            </li>
            <li class="file-item" data-node="inf_0011">
              <span class="file-icon">🏰</span> Turris Magna (Torre)
            </li>
            <li class="file-item" data-node="inf_0012">
              <span class="file-icon">💰</span> Ledger de Transacciones
            </li>
          </ul>
        </li>
      </ul>
    </div>

    <!-- Panel 2: File Viewer Viewport -->
    <div class="explorer-main-viewport">

      <!-- Content Area 1: Classic Folder Grid Viewport -->
      <div class="tab-viewport active" id="viewport-explorer">
        <!-- Dual Sticky Header Container -->
        <div class="sticky-header-container" style="position: sticky; top: -1.2rem; margin: -1.2rem -1.2rem 1.5rem -1.2rem; z-index: 10; display: flex; justify-content: space-between; align-items: center; padding: 0.6rem 1.2rem; background: linear-gradient(90deg, rgba(5,5,5,0.95) 0%, rgba(0,30,40,0.8) 100%); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(0,242,255,0.3); box-shadow: 0 8px 25px rgba(0,0,0,0.8);">
          
          <div class="folder-path-bar" style="display: flex; align-items: center; white-space: nowrap; overflow: hidden; flex: 1;">
            <span class="path-label" style="color: #c19a6b; font-family: ui-monospace, monospace; font-size: 0.65rem; font-weight: bold; margin-right: 0.8rem; flex-shrink: 0; border-right: 1px solid rgba(193,154,107,0.3); padding-right: 0.8rem; letter-spacing: 1px;">⟡ ENLACE AXIAL</span>
            <span class="path-value" id="current-folder-path" style="color: #00f2ff; font-family: ui-monospace, monospace; font-size: 0.75rem; letter-spacing: 1px; text-shadow: 0 0 5px rgba(0,242,255,0.4); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">⮞ Arcano Sagrado</span>
          </div>
          
          <div class="folder-status-bar" style="display: flex; align-items: center; font-family: ui-monospace, monospace; font-size: 0.65rem; letter-spacing: 1px; color: rgba(255,255,255,0.7); flex-shrink: 0; margin-left: 1rem;">
            <span style="margin-right: 1rem; display: flex; align-items: center;">ESTADO: <strong id="status-node-category" style="color: #c19a6b; text-shadow: 0 0 8px rgba(193,154,107,0.5); margin-left: 0.4rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 150px;">ARCHIVUM</strong></span>
            <span style="color: #00ff88; text-shadow: 0 0 8px rgba(0,255,136,0.4); background: rgba(0,255,136,0.05); padding: 0.2rem 0.5rem; border-radius: 3px; border: 1px solid rgba(0,255,136,0.2); flex-shrink: 0;">[ SECURE: OK ]</span>
          </div>
        </div>
        
        <div class="explorer-files-grid" id="explorer-files-grid">
          <!-- Populated dynamically via JS -->
        </div>
      </div>




    </div>

    <!-- Panel 3: Vitruvian Meta-Inspector (Right Panel) -->
    <div class="explorer-meta-inspector">
      <div class="inspector-section-header">🔍 INSPECTOR CRIPTOGRÁFICO</div>
      
      <div class="inspector-content">
        <div class="inspector-card-header">
          <span class="node-tag" id="inspect-category">CATEGORÍA</span>
          <span class="crypto-badge">
            <span class="badge-dot"></span> SECURE
          </span>
        </div>

        <h3 id="inspect-title">Título del Archivo</h3>
        <p id="inspect-desc">Cargando metadatos...</p>
        
        <!-- Vitruvian linguistic neon bars -> Zen Contemplative Path -->
        <div class="inspector-vitruvian-metric">
          <div class="inspector-vitruvian-header">
            <h4>🧘 Sendero del Zen Cognitivo</h4>
            <span class="debounce-hint">Sincronización Astral</span>
          </div>
          
          <div class="v-bar-container">
            <div class="v-bar-label">
              <span id="v-bar-label-1">🎭 Arqueometría: Mensura Interna</span>
              <strong id="v-poetic-val">50%</strong>
            </div>
            <div class="v-bar-track"><div class="v-bar-fill poetic" id="v-poetic-bar" style="width: 50%"></div></div>
          </div>

          <div class="v-bar-container">
            <div class="v-bar-label">
              <span id="v-bar-label-2">📐 Geometría: Forma Absoluta</span>
              <strong id="v-hermetic-val">60%</strong>
            </div>
            <div class="v-bar-track"><div class="v-bar-fill hermetic" id="v-hermetic-bar" style="width: 60%"></div></div>
          </div>

          <div class="v-bar-container">
            <div class="v-bar-label">
              <span id="v-bar-label-3">💎 DeSci: Intercambio de Conciencia</span>
              <strong id="v-technical-val">75%</strong>
            </div>
            <div class="v-bar-track"><div class="v-bar-fill technical" id="v-technical-bar" style="width: 75%"></div></div>
          </div>

          <div class="v-bar-container">
            <div class="v-bar-label">
              <span id="v-bar-label-4">⚖️ Auditoría: Verificación del Ser</span>
              <strong id="v-narrative-val">90%</strong>
            </div>
            <div class="v-bar-track"><div class="v-bar-fill narrative" id="v-narrative-bar" style="width: 90%"></div></div>
          </div>
