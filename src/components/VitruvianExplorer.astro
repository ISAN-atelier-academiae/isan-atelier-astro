  // 1. Timezone and real-time clock (Option A & C)
  function updateClock() {
    const now = new Date();
    const offset = -now.getTimezoneOffset() / 60;
    const offsetStr = `UTC${offset >= 0 ? '+' : ''}${offset}`;
    const timeStr = now.toTimeString().split(' ')[0];
    
    clockEl.innerText = `[ CICLO: 2026 // EJE-TEMPORAL: ${offsetStr} // HORA-AXIAL: ${timeStr} // STATUS: ONLINE ]`;
