// 1. D3 Graph Hologram Setup (Circular lens in header, resting at 13% opacity and synced)
let svg: any = null;
let simulation: any = null;
let gContainer: any = null;
let width = 0;
let height = 0;

function initD3Hologram() {
  const container = document.getElementById("header-hologram-container");
  if (!container) return;
  
  container.innerHTML = "";
  
  width = container.clientWidth || 220;
  height = container.clientHeight || 220;

  svg = d3.select("#header-hologram-container")
    .append("svg")
    .attr("width", "100%")
    .attr("height", "100%")
    .attr("viewBox", [0, 0, width, height]);

  // Create neon glowing filter defs
  const defs = svg.append("defs");
  const filter = defs.append("filter")
    .attr("id", "holo-neon")
    .attr("x", "-50%")
    .attr("y", "-50%")
    .attr("width", "200%")
    .attr("height", "200%");
  filter.append("feGaussianBlur").attr("stdDeviation", "3").attr("result", "coloredBlur");
  const merge = filter.append("feMerge");
  merge.append("feMergeNode").attr("in", "coloredBlur");
  merge.append("feMergeNode").attr("in", "SourceGraphic");

  gContainer = svg.append("g");

  // Add Zoom support for Hologram
  const zoom = d3.zoom()
    .scaleExtent([0.1, 5])
    .on("zoom", (event: any) => {
      gContainer.attr("transform", event.transform);
    });
  
  svg.call(zoom);

  // Hook zoom reset to the fullscreen button
  const closeBtn = document.getElementById('close-hologram-btn');
  if(closeBtn) {
    closeBtn.addEventListener('click', () => {
      svg.transition().duration(500).call(zoom.transform, d3.zoomIdentity);
    });
  }

  // D3 force simulation
  const nodes = Object.values(nodeDatabase);
  const links: any[] = [
    { source: "biblioteca", target: "convergencia" },
    { source: "convergencia", target: "sendero_serpiente" },
    { source: "bitacora", target: "biblioteca" },
    { source: "curia_cambii", target: "dossier" },
    { source: "isan_atelier", target: "biblioteca" },
    { source: "bunker", target: "manifiesto" },
    { source: "bunker", target: "reglamento_adn" },
    { source: "bunker", target: "reglamento_completo" },
    { source: "informes", target: "inf_0006" },
    { source: "informes", target: "inf_0011" },
    { source: "informes", target: "inf_0012" },
    { source: "biblioteca", target: "bunker" },
    { source: "bunker", target: "informes" }
  ];

  // Render a compact, elegant simulation
  simulation = d3.forceSimulation(nodes as any)
    .force("link", d3.forceLink(links).id((d: any) => d.id).distance(25))
    .force("charge", d3.forceManyBody().strength(-35))
    .force("center", d3.forceCenter(width / 2, height / 2))
    .force("collide", d3.forceCollide().radius((d: any) => d.size * 0.95));

  // Render lines
  const link = gContainer.append("g")
    .selectAll("line")
    .data(links)
    .join("line")
    .attr("stroke", "rgba(255, 255, 255, 0.08)")
    .attr("stroke-width", 0.75);

  // Render nodes
  const node = gContainer.append("g")
    .selectAll("g")
    .data(nodes)
    .join("g")
    .style("cursor", "pointer")
    .call(d3.drag()
      .on("start", dragstarted)
      .on("drag", dragged)
      .on("end", dragended) as any);

  node.append("circle")
    .attr("r", (d: any) => d.size * 0.5) // Sleeker nodes
    .attr("fill", (d: any) => colorMap[d.category as keyof typeof colorMap])
    .attr("stroke", "#020307")
    .attr("stroke-width", 1)
    .attr("class", "node-circle-holo");

  node.append("text")
    .attr("dy", (d: any) => d.size * 0.6 + 5)
    .attr("text-anchor", "middle")
    .attr("fill", "rgba(255, 255, 255, 0.35)")
    .attr("font-size", "5px")
    .attr("pointer-events", "none")
    .text((d: any) => d.title.substring(0, 9));

  node.on("click", (event: any, d: any) => {
    event.stopPropagation();
    selectNode(d.id);
    
    // Smooth scroll down to the File Explorer when clicking a node in the header hologram
    const explorerEl = document.querySelector(".vitruvian-explorer-wrapper");
    if (explorerEl) {
      explorerEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  });

  simulation.on("tick", () => {
    link
      .attr("x1", (d: any) => (d.source as any).x)
      .attr("y1", (d: any) => (d.source as any).y)
      .attr("x2", (d: any) => (d.target as any).x)
      .attr("y2", (d: any) => (d.target as any).y);

    node.attr("transform", (d: any) => `translate(${d.x},${d.y})`);
  });
}

function dragstarted(event: any, d: any) {
  if (!event.active) simulation.alphaTarget(0.3).restart();
  d.fx = d.x;
  d.fy = d.y;
}
function dragged(event: any, d: any) {
  d.fx = event.x;
  d.fy = event.y;
}
function dragended(event: any, d: any) {
  if (!event.active) simulation.alphaTarget(0);
  d.fx = null;
  d.fy = null;
}

// 2. Explorer Interactions
function renderFilesGrid() {
  const gridContainer = document.getElementById("explorer-files-grid");
  if (!gridContainer) return;
  gridContainer.innerHTML = "";

  // Get all nodes belonging to the active folder
  const folderNodes = Object.values(nodeDatabase).filter(n => n.folder === activeFolder);

  folderNodes.forEach(node => {
    const item = document.createElement("div");
    item.className = `hologram-card ${node.id === activeNodeId ? 'active' : ''}`;
    item.setAttribute("data-node", node.id);

    const icon = document.createElement("div");
    icon.className = "hc-icon";
    icon.innerText = node.emoji;

    const label = document.createElement("div");
    label.className = "hc-title";
    label.innerText = node.title;

    const meta = document.createElement("div");
    meta.className = "hc-meta";
    meta.innerText = `// DATA_SEC: OK`;

    item.appendChild(icon);
    item.appendChild(label);
    item.appendChild(meta);

    item.addEventListener("click", () => {
      selectNode(node.id);
    });

    item.addEventListener("mouseenter", () => {
      setInspectorBarsForNode(node.id);
    });

    item.addEventListener("mouseleave", () => {
      setInspectorBarsForNode(activeNodeId);
    });

    gridContainer.appendChild(item);
  });
}

// 2.5 Zen Scroll Logic
function initZenScrollTracker() {
  const tickerText = document.getElementById("zen-ticker-text");
  if (!tickerText) return;

  let currentTopic = "";

  // Observe headings and items to extract current topic
  const headings = document.querySelectorAll("h2, h3, .file-name, .folder-name");
  if (headings.length > 0 && typeof IntersectionObserver !== 'undefined') {
    const observer = new IntersectionObserver((entries) => {
      const visible = entries.filter(e => e.isIntersecting);
      if (visible.length > 0) {
        currentTopic = (visible[0].target as HTMLElement).innerText.replace(/[\n\r]+/g, ' ').trim();
        updateTicker();
      }
    }, { rootMargin: "0px 0px -50% 0px", threshold: 0.1 });
    headings.forEach(h => observer.observe(h));
  }

  function updateTicker() {
    const scrollPosition = window.scrollY;
    const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
    const scrollPercent = maxScroll > 0 ? scrollPosition / maxScroll : 0;

    let zenState = "[ ESTADO 0: PRATYAHARA / SHUNYATA - EL VACÍO INICIAL ]";
    if (scrollPercent > 0.15 && scrollPercent <= 0.4) {
      zenState = "[ ESTADO I: SAMATHA - LA PACIFICACIÓN ]";
    } else if (scrollPercent > 0.4 && scrollPercent <= 0.7) {
      zenState = "[ ESTADO II: VIKALPA A DHARANA - EXAMEN DE LAS FORMAS ]";
    } else if (scrollPercent > 0.7 && scrollPercent <= 0.9) {
      zenState = "[ ESTADO III: SATORI - LA VERDAD INMUTABLE ]";
    } else if (scrollPercent > 0.9) {
      zenState = "[ ESTADO IV: SAMADHI - LA INTEGRACIÓN ]";
    }

    const displayText = currentTopic ? `${zenState} // VÉRTICE: ${currentTopic.toUpperCase()}` : zenState;

    if (tickerText.innerText !== displayText) {
      tickerText.style.opacity = "0";
      setTimeout(() => {
        tickerText.innerText = displayText;
        tickerText.style.opacity = "1";
      }, 200);
    }
  }

  window.addEventListener("scroll", updateTicker, { passive: true });
  setTimeout(updateTicker, 500); // Initial call
}

// Global debounced UI update for Vitruvian Columns (1500ms debounce as per standard)
let debounceTimeout: number | undefined;

function selectNode(nodeId: string, isInitialLoad: boolean = false) {
  if (!nodeDatabase[nodeId]) return;
  activeNodeId = nodeId;
  const nodeData = nodeDatabase[nodeId];
  activeFolder = nodeData.folder;

  // Update Sidebar Active state
  document.querySelectorAll(".file-item").forEach(el => {
    const elNode = el.getAttribute("data-node");
    if (elNode === activeNodeId) {
      el.classList.add("active");
    } else {
      el.classList.remove("active");
    }
  });

  // Ensure its folder parent is expanded (ONLY if not initial load)
  if (!isInitialLoad) {
    document.querySelectorAll(".directory-folder").forEach(el => {
      const folder = el.getAttribute("data-folder");
      if (folder === activeFolder) {
        el.classList.add("expanded");
      }
    });
  }

  // Update Folder path bar (Enlace Axial)
  const pathBar = document.getElementById("current-folder-path");
  if (pathBar) {
    const baseFolder = folderPaths[activeFolder] || "⮞ Sistema Central";
    pathBar.innerHTML = `${baseFolder} <span style="color: rgba(255,255,255,0.4); margin: 0 0.5rem;">/</span> <span style="color: white; text-shadow: none;">${nodeData.title}</span>`;
  }
  
  // Update Secondary Zen Status Bar based on Concept Mapping
  const statusCat = document.getElementById("status-node-category");
  if (statusCat) {
    let zenState = "SAMATHA";
    if (nodeData.zenConcept) {
      zenState = nodeData.zenConcept;
    } else {
      if (nodeData.folder === "quartz") zenState = "VIKALPA / DHARANA";
      else if (nodeData.folder === "sanctum") zenState = "SATORI";
      else if (nodeData.folder === "metrologia") zenState = "SAMADHI";
    }
    statusCat.innerText = zenState;
  }

  // Re-render folder grid
  renderFilesGrid();

  // Instant update for text metadata
  const title = document.getElementById("inspect-title");
  const desc = document.getElementById("inspect-desc");
  const category = document.getElementById("inspect-category");
  const actionBtn = document.getElementById("inspect-action-btn") as HTMLAnchorElement;
  const hashVal = document.getElementById("inspect-hash");
  const resonancia = document.getElementById("inspect-resonancia");

  if (title) title.innerText = `${nodeData.emoji} ${nodeData.title}`;
  if (desc) desc.innerText = nodeData.desc;
  if (category) {
    category.innerText = nodeData.category === "core" ? "Bóveda Principal" :
                         nodeData.category === "portal" ? "Portal Clave" :
                         nodeData.category === "bunker" ? "Búnker Soberano" : "Informe Técnico";
    category.style.borderColor = colorMap[nodeData.category as keyof typeof colorMap];
    category.style.color = colorMap[nodeData.category as keyof typeof colorMap];
    category.style.background = `rgba(${nodeData.category === 'portal' ? '0, 242, 255' : nodeData.category === 'core' ? '251, 191, 36' : nodeData.category === 'bunker' ? '255, 46, 46' : '192, 132, 252'}, 0.08)`;
  }
  if (actionBtn) actionBtn.href = nodeData.url;
  if (hashVal) hashVal.innerText = nodeData.hash;
  if (resonancia) resonancia.innerText = nodeData.resonancia;

  // Debounced update for Vitruvian Columns (Gestalt Delay)
  if (debounceTimeout) clearTimeout(debounceTimeout);

  // Pre-highlight indicators (setting opacity to 35% briefly to show it is sensing)
  document.querySelectorAll(".v-bar-fill").forEach(el => {
    (el as HTMLElement).style.opacity = "0.35";
  });

  debounceTimeout = window.setTimeout(() => {
    setInspectorBarsForNode(nodeId);

    document.querySelectorAll(".v-bar-fill").forEach(el => {
      (el as HTMLElement).style.opacity = "1";
    });
  }, 1500);

  // Sync D3 Hologram selection (Highlight Node)
  if (svg) {
    svg.selectAll(".node-circle-holo")
      .attr("stroke", (n: any) => n.id === nodeId ? "#ffffff" : "#020307")
      .attr("stroke-width", (n: any) => n.id === nodeId ? 2.2 : 1)
      .attr("filter", (n: any) => n.id === nodeId ? "url(#holo-neon)" : null);

    svg.selectAll("text")
      .attr("fill", (n: any) => n.id === nodeId ? "#ffffff" : "rgba(255, 255, 255, 0.35)")
      .attr("font-weight", (n: any) => n.id === nodeId ? "bold" : "normal");
  }
  // Zero-Trust PIN Gate: expose active node data
  (window as any).__ztActiveNodeData = nodeData;
}

// 3. Scroll Sync & 10-Color Atmospheric Vitruvian Column
function setupScrollSync() {
  const bar = document.getElementById("barra-vitruvio");
  const badge = document.getElementById("vitruvio-sensor-badge");
  const sIcon = document.getElementById("sensor-icon");
  const sTheme = document.getElementById("sensor-theme");
  
  if (!bar || !badge || !sIcon || !sTheme) return;

  let isScrollingTimeout: number | undefined;

  window.addEventListener("scroll", () => {
    // 1. Calculate scroll percentage
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const scrollPercent = Math.min(Math.max((scrollTop / (docHeight || 1)) * 100, 0), 100);
    
    bar.style.height = `${scrollPercent}%`;

    // 2. Active Scrolling breathe state
    bar.classList.add("scrolling");
    badge.classList.add("active");
    
    if (isScrollingTimeout) clearTimeout(isScrollingTimeout);
    isScrollingTimeout = window.setTimeout(() => {
      bar.classList.remove("scrolling");
      badge.classList.remove("active");
    }, 1500); // Rests back to 13% opacity after 1500ms of no scrolling (Gestalt)

    // 3. 10-Color & Theme Cognitive Sensor Logic
    const activeTheme = vitruvianThemes.find(t => scrollPercent >= t.percentMin && scrollPercent < t.percentMax) 
      || vitruvianThemes[vitruvianThemes.length - 1];

    // Update Floating bar style
    bar.style.background = activeTheme.color;
    bar.style.color = activeTheme.color;
    bar.style.boxShadow = `0 0 12px ${activeTheme.color}`;

    // Update Floating Badge Style and Text
    sIcon.innerText = activeTheme.icon;
    sTheme.innerText = activeTheme.name;
    sTheme.style.color = activeTheme.color;
    badge.style.borderColor = `rgba(${hexToRgb(activeTheme.color)}, 0.3)`;
    badge.style.boxShadow = `0 8px 32px 0 rgba(0, 0, 0, 0.5), 0 0 10px rgba(${hexToRgb(activeTheme.color)}, 0.15)`;
  });
}

// Helper to convert hex to RGB
function hexToRgb(hex: string) {
  const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
  return result ? `${parseInt(result[1], 16)}, ${parseInt(result[2], 16)}, ${parseInt(result[3], 16)}` : '255, 255, 255';
}



