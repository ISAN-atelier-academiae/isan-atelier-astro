// ======================================================
// 🔐 ZERO-TRUST PIN GATE — SISTEMA CRIPTOGRÁFICO SOBERANO
// Nodes with category 'bunker' or 'reports' are protected.
// PIN is verified via WebCrypto SHA-256 (client-side).
// Correct PIN: ISAN2026 (numeric pads use digits only so
// we map: I=4, S=7, A=2, N=6, 2=2, 0=0, 2=2, 6=6 → PIN: 47262026)
// SHA-256 of "47262026": pre-computed below.
// ======================================================

(function initZeroTrust() {
  // SHA-256 of the PIN string "47262026"
  const CORRECT_PIN_HASH = "03c9cc6eb0b243b5837ff5657b0ef806e8f5fee81a390369e777ef7c543cbf5b";

  // Private node categories that require PIN
  const PRIVATE_CATEGORIES = ["bunker", "reports"];

  const overlay = document.getElementById("zt-gate-overlay");
  const card = document.getElementById("zt-gate-card");
  const nodeLabel = document.getElementById("zt-node-label");
  const statusEl = document.getElementById("zt-status");
  const confirmBtn = document.getElementById("zt-confirm");
  const clearBtn = document.getElementById("zt-clear");
  const cancelBtn = document.getElementById("zt-cancel");
  const keys = document.querySelectorAll(".zt-key[data-key]");
  const dots = document.querySelectorAll(".zt-pin-dot");

  let pinBuffer = "";
  let pendingUrl = "";

  async function sha256(str: string): Promise<string> {
    const buf = await crypto.subtle.digest("SHA-256", new TextEncoder().encode(str));
    return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, "0")).join("");
  }

  function updateDots() {
    dots.forEach((dot, i) => {
      dot.classList.toggle("filled", i < pinBuffer.length);
      dot.classList.remove("error", "success");
    });
  }

  function flashError() {
    dots.forEach(dot => dot.classList.add("error"));
    if (card) {
      card.style.animation = "zt-shake 0.35s ease";
      setTimeout(() => { if (card) card.style.animation = ""; }, 350);
    }
    if (statusEl) {
      statusEl.textContent = "⛔ ACCESO DENEGADO — PROTOCOLO SECURE NODE ACTIVO";
      statusEl.classList.add("error");
    }
    setTimeout(() => {
      pinBuffer = "";
      updateDots();
      if (statusEl) {
        statusEl.textContent = "INGRESA EL CÓDIGO DE ACCESO SOBERANO";
        statusEl.classList.remove("error");
      }
    }, 1800);
  }

  function flashSuccess(url: string) {
    dots.forEach(dot => { dot.classList.remove("error"); dot.classList.add("success"); });
    if (statusEl) {
      statusEl.textContent = "✅ IDENTIDAD VERIFICADA — ACCEDIENDO...";
      statusEl.classList.remove("error");
      statusEl.classList.add("success");
    }
    setTimeout(() => {
      closeGate();
      window.open(url, "_blank");
    }, 900);
  }

  function openGate(url: string, nodeName: string) {
    pendingUrl = url;
    pinBuffer = "";
    updateDots();
    if (statusEl) {
      statusEl.textContent = "INGRESA EL CÓDIGO DE ACCESO SOBERANO";
      statusEl.classList.remove("error", "success");
    }
    if (nodeLabel) nodeLabel.textContent = `🔒 ${nodeName}`;
    if (overlay) {
      overlay.classList.add("active");
      overlay.removeAttribute("aria-hidden");
    }
    // Focus trap
    setTimeout(() => { if (confirmBtn) (confirmBtn as HTMLElement).focus(); }, 100);
  }

  function closeGate() {
    if (overlay) {
      overlay.classList.remove("active");
      overlay.setAttribute("aria-hidden", "true");
    }
    if (statusEl) statusEl.classList.remove("error", "success");
    pinBuffer = "";
    pendingUrl = "";
    updateDots();
  }

  async function verifyPin() {
    if (pinBuffer.length === 0) return;
    const hash = await sha256(pinBuffer);
    if (hash === CORRECT_PIN_HASH) {
      flashSuccess(pendingUrl);
    } else {
      flashError();
    }
  }

  // Key press handlers
  keys.forEach(key => {
    key.addEventListener("click", () => {
      if (pinBuffer.length >= 8) return;
      pinBuffer += key.getAttribute("data-key") || "";
      updateDots();
      // Auto-verify when 8 digits entered
      if (pinBuffer.length === 8) verifyPin();
    });
  });

  if (clearBtn) {
    clearBtn.addEventListener("click", () => {
      pinBuffer = pinBuffer.slice(0, -1);
      updateDots();
    });
  }

  if (confirmBtn) confirmBtn.addEventListener("click", () => verifyPin());
  if (cancelBtn) cancelBtn.addEventListener("click", () => closeGate());

  // Close on backdrop click
  if (overlay) {
    overlay.addEventListener("click", (e) => {
      if (e.target === overlay) closeGate();
    });
  }

  // Keyboard support
  document.addEventListener("keydown", (e) => {
    if (!overlay || !overlay.classList.contains("active")) return;
    if (e.key >= "0" && e.key <= "9") {
      if (pinBuffer.length < 8) {
        pinBuffer += e.key;
        updateDots();
        if (pinBuffer.length === 8) verifyPin();
      }
    } else if (e.key === "Backspace") {
      pinBuffer = pinBuffer.slice(0, -1);
      updateDots();
    } else if (e.key === "Enter") {
      verifyPin();
    } else if (e.key === "Escape") {
      closeGate();
    }
  });

  // Intercept action button
  const actionBtn = document.getElementById("inspect-action-btn") as HTMLAnchorElement | null;
  if (actionBtn) {
    actionBtn.addEventListener("click", (e) => {
      e.preventDefault();
      const currentUrl = actionBtn.href;
      if (!currentUrl || currentUrl === window.location.href + "#" || currentUrl === "#") return;
      // Get active node data
      const activeData = (window as any).__ztActiveNodeData;
      if (activeData && PRIVATE_CATEGORIES.includes(activeData.category)) {
        openGate(currentUrl, activeData.title);
      } else {
        window.open(currentUrl, "_blank");
      }
    });
  }

  // Export helper so selectNode can expose active node data
  (window as any).__ztOpenGate = openGate;
  (window as any).__ztActiveNodeData = null;


})();
</script>

