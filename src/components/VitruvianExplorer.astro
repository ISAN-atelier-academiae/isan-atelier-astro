// --- Holograma Fullscreen Logic ---
const hologramFrame = document.getElementById('hologram-trigger-frame');
const closeHologramBtn = document.getElementById('close-hologram-btn');
const hologramHoverWidget = document.getElementById('hologram-hover-widget');

if (hologramFrame && closeHologramBtn) {
  hologramFrame.addEventListener('click', (e) => {
    // Prevent triggering if clicked on the close button
    if (e.target === closeHologramBtn) return;
    
    hologramFrame.classList.add('fullscreen-hologram');
    closeHologramBtn.classList.remove('hidden');
    setTimeout(() => closeHologramBtn.classList.remove('opacity-0'), 100); // fade in
    
    // Hide hover widget while in fullscreen
    if(hologramHoverWidget) hologramHoverWidget.style.display = 'none';
  });

  closeHologramBtn.addEventListener('click', (e) => {
    e.stopPropagation(); // prevent re-triggering frame click
    closeHologramBtn.classList.add('opacity-0');
    setTimeout(() => {
      closeHologramBtn.classList.add('hidden');
      hologramFrame.classList.remove('fullscreen-hologram');
      if(hologramHoverWidget) hologramHoverWidget.style.display = '';
    }, 300);
  });
  
  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && hologramFrame.classList.contains('fullscreen-hologram')) {
      closeHologramBtn.click();
    }
  });
}

