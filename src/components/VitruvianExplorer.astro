function getMetricsForNode(nodeId: string) {
  if (nodeLibraryMetrics[nodeId]) {
    return nodeLibraryMetrics[nodeId];
  }
  return { qr: 2, pdf: 10, reports: 5, sync: 90 };
}

// Global helper to set inspector bars instantly representing document metrics
function setInspectorBarsForNode(nodeId: string) {
  const metrics = getMetricsForNode(nodeId);

  const poeticVal = document.getElementById("v-poetic-val");
  const poeticBar = document.getElementById("v-poetic-bar");
  const hermeticVal = document.getElementById("v-hermetic-val");
  const hermeticBar = document.getElementById("v-hermetic-bar");
  const techVal = document.getElementById("v-technical-val");
  const techBar = document.getElementById("v-technical-bar");
  const narrVal = document.getElementById("v-narrative-val");
  const narrBar = document.getElementById("v-narrative-bar");

  const label1 = document.getElementById("v-bar-label-1");
  const label2 = document.getElementById("v-bar-label-2");
  const label3 = document.getElementById("v-bar-label-3");
  const label4 = document.getElementById("v-bar-label-4");

  if (label1) label1.innerText = "📱 Códigos QR Sello";
  if (label2) label2.innerText = "📄 Documentos PDF";
  if (label3) label3.innerText = "📊 Informes de Red";
  if (label4) label4.innerText = "🧘 Estatus de Sincronía";

  // Calculate percentages for widths (max QR = 10, max PDF = 30, max Reports = 20)
  const qrPercent = Math.min((metrics.qr / 10) * 100, 100);
  const pdfPercent = Math.min((metrics.pdf / 30) * 100, 100);
  const reportsPercent = Math.min((metrics.reports / 20) * 100, 100);
  const syncPercent = metrics.sync;

  if(poeticVal) poeticVal.innerText = `${metrics.qr} QR`;
  if(poeticBar) poeticBar.style.width = qrPercent + "%";
  if(hermeticVal) hermeticVal.innerText = `${metrics.pdf} PDF`;
  if(hermeticBar) hermeticBar.style.width = pdfPercent + "%";
  if(techVal) techVal.innerText = `${metrics.reports} INF`;
  if(techBar) techBar.style.width = reportsPercent + "%";
  if(narrVal) narrVal.innerText = `${metrics.sync}%`;
  if(narrBar) narrBar.style.width = syncPercent + "%";
}

