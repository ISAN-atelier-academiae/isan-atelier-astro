// Setup Zen Command Bar
function setupCommandBar() {
  const commandBar = document.getElementById("sovereign-command-bar");
  const cbInput = document.getElementById("command-bar-input") as HTMLInputElement;
  const resultsList = document.getElementById("cb-results-list");
  const resultsTitle = document.getElementById("cb-results-title");

  if (!commandBar) return;

  function showCommandBar() {
    commandBar.style.display = "flex";
    if (cbInput) {
      cbInput.value = "";
      cbInput.focus();
      renderCommandBarResults("");
    }
  }

  function hideCommandBar() {
    commandBar.style.display = "none";
  }

  // Keyboard listeners (Ctrl+K to toggle, Esc to close)
  window.addEventListener("keydown", (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === "k") {
      e.preventDefault();
      e.stopPropagation();
      e.stopImmediatePropagation();
      if (commandBar.style.display === "flex") {
        hideCommandBar();
      } else {
        showCommandBar();
      }
    }
    if (e.key === "Escape") {
      hideCommandBar();
    }
  }, true); // Use capturing to prevent Starlight's default Ctrl+K index download

  // Close when clicking outside of the search box
  commandBar.addEventListener("click", (e) => {
    if (e.target === commandBar) {
      hideCommandBar();
    }
  });

  // Wire up keyword tags
  document.querySelectorAll(".cb-keyword-tag").forEach(tag => {
    tag.addEventListener("click", () => {
      const keyword = tag.getAttribute("data-keyword");
      if (keyword && cbInput) {
        cbInput.value = keyword;
        renderCommandBarResults(keyword);
        cbInput.focus();
      }
    });
  });

  // Input listener for search and commands
