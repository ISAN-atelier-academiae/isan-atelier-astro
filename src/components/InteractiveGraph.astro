// Colors matching our premium theme
const colorMap = {
  portal: "#00f2ff", // Cyan
  core: "#fbbf24",   // Gold/Amber
  bunker: "#ff2e2e", // Crimson/Ruby
  reports: "#c084fc" // Violet/Purple
};

let width = 0;
let height = 0;
let svg: any = null;
let simulation: any = null;
let zoomBehavior: any = null;
let gContainer: any = null;

function initGraph() {
  const container = document.getElementById("graph-container");
  if (!container) return;

  // Clear previous SVG if hot reloading
  container.innerHTML = "";

  width = container.clientWidth;
  height = container.clientHeight;

  // Create SVG
  svg = d3.select("#graph-container")
    .append("svg")
    .attr("width", "100%")
    .attr("height", "100%")
    .attr("viewBox", [0, 0, width, height]);

  // Create neon glowing filter defs
  const defs = svg.append("defs");
  
  // Neon glow filter
  const filter = defs.append("filter")
    .attr("id", "neon-glow")
    .attr("x", "-50%")
    .attr("y", "-50%")
    .attr("width", "200%")
    .attr("height", "200%");

  filter.append("feGaussianBlur")
    .attr("stdDeviation", "6")
    .attr("result", "coloredBlur");

  const merge = filter.append("feMerge");
  merge.append("feMergeNode").attr("in", "coloredBlur");
  merge.append("feMergeNode").attr("in", "SourceGraphic");

  // Glowing group for all zoomable elements
  gContainer = svg.append("g").attr("class", "graph-zoom-group");

  // Setup Zoom Behavior
  zoomBehavior = d3.zoom()
    .scaleExtent([0.2, 5])
    .on("zoom", (event) => {
      gContainer.attr("transform", event.transform);
    });

  svg.call(zoomBehavior);

  // Simulation settings
  simulation = d3.forceSimulation(graphData.nodes as any)
    .force("link", d3.forceLink(graphData.links as any).id((d: any) => d.id).distance((d: any) => 50 + (20 - d.value) * 3))
    .force("charge", d3.forceManyBody().strength(-220))
    .force("center", d3.forceCenter(width / 2, height / 2))
    .force("collide", d3.forceCollide().radius((d: any) => d.size * 1.6).iterations(2));

  // Render links (lines)
  const link = gContainer.append("g")
    .attr("class", "links")
    .selectAll("line")
    .data(graphData.links)
    .join("line")
    .attr("stroke", "rgba(255,255,255,0.08)")
    .attr("stroke-width", (d: any) => d.value * 0.8)
    .attr("transition", "stroke 0.3s ease, stroke-width 0.3s ease");

  // Render nodes (groups for circle + text)
  const node = gContainer.append("g")
    .attr("class", "nodes")
    .selectAll("g")
    .data(graphData.nodes)
    .join("g")
    .attr("class", "node-group")
    .call(d3.drag()
      .on("start", dragstarted)
      .on("drag", dragged)
      .on("end", dragended) as any);

  // Inner glow circle for key nodes
  node.append("circle")
    .attr("r", (d: any) => d.size * 1.3)
    .attr("fill", "transparent")
    .attr("stroke", (d: any) => colorMap[d.category as keyof typeof colorMap])
    .attr("stroke-opacity", 0.15)
    .attr("stroke-width", 2)
    .attr("class", "glow-ring");

  // Main node circle
  node.append("circle")
    .attr("r", (d: any) => d.size)
    .attr("fill", (d: any) => colorMap[d.category as keyof typeof colorMap])
    .attr("stroke", "#020307")
    .attr("stroke-width", 1.5)
    .attr("style", "cursor: pointer; transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);")
    .attr("class", "node-circle");

  // Node Labels
  node.append("text")
    .attr("dy", (d: any) => d.size + 15)
    .attr("text-anchor", "middle")
    .attr("fill", "rgba(255, 255, 255, 0.7)")
    .attr("font-size", "9px")
    .attr("font-family", "var(--font-sans)")
    .attr("font-weight", 500)
    .attr("letter-spacing", "0.2px")
    .attr("pointer-events", "none")
    .text((d: any) => d.title);

  // Interaction: Hover Effects
  node.on("mouseenter", function(event: any, d: any) {
    highlightNode(d, this);
  });

  node.on("mouseleave", function() {
    resetHighlight();
  });

  // Interaction: Click to lock/update Details Card
  node.on("click", (event: any, d: any) => {
    event.stopPropagation();
    updateDetailsCard(d);
  });

  // Background click resets details card to placeholder and removes highlight lock
  svg.on("click", () => {
    resetDetailsCard();
  });

  // Simulation tick
  simulation.on("tick", () => {
    link
      .attr("x1", (d: any) => (d.source as any).x)
      .attr("y1", (d: any) => (d.source as any).y)
      .attr("x2", (d: any) => (d.target as any).x)
      .attr("y2", (d: any) => (d.target as any).y);

    node.attr("transform", (d: any) => `translate(${d.x},${d.y})`);
  });

  // Highlights and selects the hovered/searched node
  function highlightNode(targetNode: any, element: any) {
    // Zoom and pulse effect on the hovered element
    d3.select(element).select(".node-circle")
      .attr("r", targetNode.size * 1.4)
      .attr("filter", "url(#neon-glow)");

    d3.select(element).select("text")
      .attr("fill", "#ffffff")
      .attr("font-size", "10px")
      .attr("font-weight", "bold");

    // Fade all other nodes and lines
    node.style("opacity", (n: any) => (n.id === targetNode.id || isConnected(targetNode, n)) ? 1 : 0.2);
    link
      .style("stroke", (l: any) => ((l.source as any).id === targetNode.id || (l.target as any).id === targetNode.id) ? colorMap[targetNode.category as keyof typeof colorMap] : "rgba(255,255,255,0.03)")
      .style("stroke-opacity", (l: any) => ((l.source as any).id === targetNode.id || (l.target as any).id === targetNode.id) ? 0.9 : 0.2)
      .attr("stroke-width", (l: any) => ((l.source as any).id === targetNode.id || (l.target as any).id === targetNode.id) ? l.value * 1.5 : l.value * 0.8);
      
    // Update floating details temporarily on hover (only if no clicked node locked)
    if (!isCardLocked) {
      updateDetailsCard(targetNode, false);
    }
  }

  function resetHighlight() {
    node.select(".node-circle")
      .attr("r", (d: any) => d.size)
      .attr("filter", null);

    node.select("text")
      .attr("fill", "rgba(255, 255, 255, 0.7)")
      .attr("font-size", "9px")
      .attr("font-weight", 500);

    node.style("opacity", 1);
    link
      .style("stroke", "rgba(255,255,255,0.08)")
      .style("stroke-opacity", 0.6)
      .attr("stroke-width", (d: any) => d.value * 0.8);
      
    if (!isCardLocked) {
      resetDetailsCard();
    }
  }

  function isConnected(a: any, b: any) {
    return graphData.links.some(l => 
      ((l.source as any).id === a.id && (l.target as any).id === b.id) || 
      ((l.source as any).id === b.id && (l.target as any).id === a.id)
    );
  }
}

// State for locked details card
let isCardLocked = false;

function updateDetailsCard(nodeData: any, lock = true) {
  const placeholder = document.getElementById("details-placeholder");
  const content = document.getElementById("details-content");
  const title = document.getElementById("details-title");
  const category = document.getElementById("details-category");
  const desc = document.getElementById("details-desc");
  const link = document.getElementById("details-link") as HTMLAnchorElement;

  const integrityHash = document.getElementById("integrity-hash");
  const resonanciaVal = document.getElementById("resonancia-val");

  // Vitruvian Bars elements
  const poeticBar = document.getElementById("poetic-bar");
  const poeticVal = document.getElementById("poetic-val");
  const hermeticBar = document.getElementById("hermetic-bar");
  const hermeticVal = document.getElementById("hermetic-val");
  const technicalBar = document.getElementById("technical-bar");
  const technicalVal = document.getElementById("technical-val");
  const narrativeBar = document.getElementById("narrative-bar");
  const narrativeVal = document.getElementById("narrative-val");

  if (!placeholder || !content || !title || !category || !desc || !link) return;

  if (lock) {
    isCardLocked = true;
  }

  // Update text
  title.innerText = nodeData.title;
  category.innerText = nodeData.category === "core" ? "Bóveda Principal" :
                       nodeData.category === "portal" ? "Portal Clave" :
                       nodeData.category === "bunker" ? "Búnker Soberano" : "Informe Técnico";
  
  // Color the category tag
  category.style.borderColor = colorMap[nodeData.category as keyof typeof colorMap];
  category.style.color = colorMap[nodeData.category as keyof typeof colorMap];
  category.style.background = `rgba(${nodeData.category === 'portal' ? '0, 242, 255' : nodeData.category === 'core' ? '251, 191, 36' : nodeData.category === 'bunker' ? '255, 46, 46' : '192, 132, 252'}, 0.08)`;

  desc.innerText = nodeData.desc;
  
  if (nodeData.url === "/") {
    link.style.display = "none";
  } else {
    link.style.display = "inline-block";
    link.href = nodeData.url;
  }

  // Update Vitruvian Bars
  const vit = nodeData.vitruvian || { poetic: 50, hermetic: 50, technical: 50, narrative: 50 };
  if (poeticBar && poeticVal) { poeticBar.style.width = `${vit.poetic}%`; poeticVal.innerText = `${vit.poetic}%`; }
  if (hermeticBar && hermeticVal) { hermeticBar.style.width = `${vit.hermetic}%`; hermeticVal.innerText = `${vit.hermetic}%`; }
  if (technicalBar && technicalVal) { technicalBar.style.width = `${vit.technical}%`; technicalVal.innerText = `${vit.technical}%`; }
  if (narrativeBar && narrativeVal) { narrativeBar.style.width = `${vit.narrative}%`; narrativeVal.innerText = `${vit.narrative}%`; }

  // Update Crypto Validador
  if (integrityHash) integrityHash.innerText = nodeData.hash || "a68d716cf9ef673196f7c6e61f215e98516ee71a7d65691e847c1ba0c18d18f4";
  if (resonanciaVal) resonanciaVal.innerText = nodeData.resonancia || "1.57714881";

  // Display details content
  placeholder.style.display = "none";
  content.style.display = "block";
}

function resetDetailsCard() {
  isCardLocked = false;
  const placeholder = document.getElementById("details-placeholder");
  const content = document.getElementById("details-content");
  
  // Vitruvian Bars elements
  const poeticBar = document.getElementById("poetic-bar");
  const poeticVal = document.getElementById("poetic-val");
  const hermeticBar = document.getElementById("hermetic-bar");
  const hermeticVal = document.getElementById("hermetic-val");
  const technicalBar = document.getElementById("technical-bar");
  const technicalVal = document.getElementById("technical-val");
  const narrativeBar = document.getElementById("narrative-bar");
  const narrativeVal = document.getElementById("narrative-val");

  const integrityHash = document.getElementById("integrity-hash");
  const resonanciaVal = document.getElementById("resonancia-val");

  if (placeholder && content) {
    placeholder.style.display = "flex";
    content.style.display = "none";
  }

  // Reset Vitruvian Bars to repository average
  if (poeticBar && poeticVal) { poeticBar.style.width = "50%"; poeticVal.innerText = "50%"; }
  if (hermeticBar && hermeticVal) { hermeticBar.style.width = "60%"; hermeticVal.innerText = "60%"; }
  if (technicalBar && technicalVal) { technicalBar.style.width = "75%"; technicalVal.innerText = "75%"; }
  if (narrativeBar && narrativeVal) { narrativeBar.style.width = "45%"; narrativeVal.innerText = "45%"; }

  // Reset Crypto Validador
  if (integrityHash) integrityHash.innerText = "a68d716cf9ef673196f7c6e61f215e98516ee71a7d65691e847c1ba0c18d18f4";
  if (resonanciaVal) resonanciaVal.innerText = "1.57714881";
}

// D3 Drag functions
function dragstarted(event: any, d: any) {
  if (!event.active) simulation.alphaTarget(0.3).restart();
  d.fx = d.x;
  d.fy = d.y;
}

function dragged(event: any, d: any) {
  d.fx = event.x;
  d.fy = event.y;
}

function dragended(event: any, d: any) {
  if (!event.active) simulation.alphaTarget(0);
  d.fx = null;
  d.fy = null;
}

// Zoom controls setup
function setupZoomControls() {
  const zoomInBtn = document.getElementById("zoom-in");
  const zoomOutBtn = document.getElementById("zoom-out");
  const zoomResetBtn = document.getElementById("zoom-reset");

  zoomInBtn?.addEventListener("click", () => {
    svg.transition().duration(300).call(zoomBehavior.scaleBy, 1.3);
  });

  zoomOutBtn?.addEventListener("click", () => {
    svg.transition().duration(300).call(zoomBehavior.scaleBy, 0.7);
  });

  zoomResetBtn?.addEventListener("click", () => {
    svg.transition().duration(400).call(zoomBehavior.transform, d3.zoomIdentity);
  });
}

// Search bar setup
function setupSearch() {
  const searchInput = document.getElementById("node-search") as HTMLInputElement;
  const clearBtn = document.getElementById("search-clear");

  if (!searchInput) return;

  searchInput.addEventListener("input", (e) => {
    const q = searchInput.value.toLowerCase().trim();
    
    if (q.length > 0) {
      if (clearBtn) clearBtn.style.display = "block";
      
      const nodeGroups = gContainer.selectAll(".node-group");
      
      // Filter matching nodes
      const matches = graphData.nodes.filter((n: any) => 
        n.title.toLowerCase().includes(q) || 
        n.desc.toLowerCase().includes(q) ||
        n.id.toLowerCase().includes(q)
      );

      if (matches.length > 0) {
        // Highlight matching nodes
        nodeGroups.style("opacity", (n: any) => 
          matches.some((m: any) => m.id === n.id) ? 1 : 0.15
        );

        // Highlight matching circles with neon glow
        nodeGroups.select(".node-circle")
          .attr("r", (n: any) => matches.some((m: any) => m.id === n.id) ? n.size * 1.3 : n.size)
          .attr("filter", (n: any) => matches.some((m: any) => m.id === n.id) ? "url(#neon-glow)" : null);

        // Select the first matched node and focus/lock it
        const firstMatch = matches[0] as any;
        updateDetailsCard(firstMatch, true);
        
        // Zoom camera to focus on this node
        const zoomScale = 1.6;
        const transform = d3.zoomIdentity
          .translate(width / 2 - firstMatch.x * zoomScale, height / 2 - firstMatch.y * zoomScale)
          .scale(zoomScale);

        svg.transition().duration(500).call(zoomBehavior.transform, transform);

        gContainer.selectAll("line")
          .style("stroke-opacity", 0.05)
          .style("stroke", "rgba(255,255,255,0.02)");
      }
    } else {
      if (clearBtn) clearBtn.style.display = "none";
      resetSearchAndVisuals();
    }
  });
  
  clearBtn?.addEventListener("click", () => {
    searchInput.value = "";
    clearBtn.style.display = "none";
    resetSearchAndVisuals();
  });

  function resetSearchAndVisuals() {
    const nodeGroups = gContainer.selectAll(".node-group");
    nodeGroups.style("opacity", 1);
    nodeGroups.select(".node-circle")
      .attr("r", (d: any) => d.size)
      .attr("filter", null);
      
    gContainer.selectAll("line")
      .style("stroke", "rgba(255,255,255,0.08)")
      .style("stroke-opacity", 0.6)
      .attr("stroke-width", (d: any) => d.value * 0.8);
      
    resetDetailsCard();
    
    // Zoom out to center
    svg.transition().duration(500).call(
      zoomBehavior.transform,
      d3.zoomIdentity
    );
  }
}

// Trigger initialization on load and window resize
function runInit() {
  initGraph();
  setupZoomControls();
  setupSearch();
}

if (document.readyState === "complete" || document.readyState === "interactive") {
  runInit();
} else {
  window.addEventListener("DOMContentLoaded", runInit);
}

document.addEventListener("astro:page-load", runInit);

window.addEventListener("resize", () => {
  const container = document.getElementById("graph-container");
  if (!container || !svg || !simulation) return;
  
  width = container.clientWidth;
  height = container.clientHeight;
  
  simulation.force("center", d3.forceCenter(width / 2, height / 2));
  simulation.alpha(0.3).restart();
});
</script>
