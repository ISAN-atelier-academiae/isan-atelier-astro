  margin-bottom: 0.3rem;
  font-family: monospace;
}

.breaking-badge {
  color: var(--color-neon-red);
  text-shadow: 0 0 5px var(--color-neon-red-glow);
}

.breaking-category {
  color: rgba(255, 255, 255, 0.4);
}

.breaking-title {
