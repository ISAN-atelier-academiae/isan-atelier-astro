  color: var(--color-neon-cyan) !important;
  padding: 0.5rem 1rem;
  border-radius: 4px;
  font-size: 0.68rem;
  font-weight: 800;
  letter-spacing: 0.5px;
  text-decoration: none !important;
  transition: all 0.25s ease;
