.p-putei:hover .app-title { color: var(--color-neon-cyan); text-shadow: 0 0 10px var(--color-neon-cyan-glow); }
.p-putei .app-neon-line { background: var(--color-neon-cyan); box-shadow: 0 0 8px var(--color-neon-cyan); }

.p-asientos:hover .app-title { color: #ff2e2e; text-shadow: 0 0 10px rgba(255, 46, 46, 0.6); }
.p-asientos .app-neon-line { background: #ff2e2e; box-shadow: 0 0 8px #ff2e2e; }

.p-pyramidis:hover .app-title { color: var(--color-neon-gold); text-shadow: 0 0 10px var(--color-neon-gold-glow); }
.p-pyramidis .app-neon-line { background: var(--color-neon-gold); box-shadow: 0 0 8px var(--color-neon-gold); }

.p-urbs:hover .app-title { color: #10b981; text-shadow: 0 0 10px rgba(16, 185, 129, 0.6); }
.p-urbs .app-neon-line { background: #10b981; box-shadow: 0 0 8px #10b981; }

.p-callis:hover .app-title { color: var(--color-neon-violet); text-shadow: 0 0 10px var(--color-neon-violet-glow); }
.p-callis .app-neon-line { background: var(--color-neon-violet); box-shadow: 0 0 8px var(--color-neon-violet); }

.p-centralis:hover .app-title { color: #ff8c00; text-shadow: 0 0 10px rgba(255, 140, 0, 0.6); }
.p-centralis .app-neon-line { background: #ff8c00; box-shadow: 0 0 8px #ff8c00; }

/* Section 2: Main Asiento Article styling */
.main-asiento-wrapper {
  margin-bottom: 2rem;
