}

.pilar-progress-bar .fill.gold { background: var(--color-neon-gold); box-shadow: 0 0 6px var(--color-neon-gold); }
.pilar-progress-bar .fill.violet { background: var(--color-neon-violet); box-shadow: 0 0 6px var(--color-neon-violet); }
.pilar-progress-bar .fill.cyan { background: var(--color-neon-cyan); box-shadow: 0 0 6px var(--color-neon-cyan); }

.border-gold:hover { border-color: var(--color-neon-gold); box-shadow: 0 8px 32px var(--color-neon-gold-glow); }
.border-violet:hover { border-color: var(--color-neon-violet); box-shadow: 0 8px 32px var(--color-neon-violet-glow); }
.border-cyan:hover { border-color: var(--color-neon-cyan); box-shadow: 0 8px 32px var(--color-neon-cyan-glow); }

.text-violet { color: var(--color-neon-violet) !important; }

