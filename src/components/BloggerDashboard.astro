/* Widget 1: DIARIUM // DAILY NEWS Terminal */
.terminal-widget {
  padding: 0;
  overflow: hidden;
  margin-bottom: 1.5rem;
}

.terminal-widget-header {
  background: rgba(0, 242, 255, 0.08);
  border-bottom: 1px solid var(--color-glass-border);
  padding: 0.6rem 1rem;
  font-family: monospace;
  font-size: 0.65rem;
  font-weight: 800;
  color: var(--color-neon-cyan);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  letter-spacing: 1px;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 8px;
}

.daily-counter-badge {
  background: rgba(0, 242, 255, 0.12);
  color: var(--color-neon-cyan);
  border: 1px solid rgba(0, 242, 255, 0.3);
  font-size: 0.55rem;
  padding: 1px 6px;
  border-radius: 3px;
  font-weight: bold;
  letter-spacing: 0.5px;
  text-shadow: 0 0 5px var(--color-neon-cyan-glow);
}

.live-pulse-dot {
  width: 7px;
  height: 7px;
  background: var(--color-neon-red);
  border-radius: 50%;
  box-shadow: 0 0 8px var(--color-neon-red);
  animation: pulse-red 1.2s infinite;
}

@keyframes pulse-red {
  0% { transform: scale(1); opacity: 1; }
  50% { transform: scale(0.9); opacity: 0.4; }
  100% { transform: scale(1); opacity: 1; }
}

.terminal-screen {
  background: #020204;
  padding: 1.25rem 1rem;
  position: relative;
  overflow: hidden;
}

.crt-scanline {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
  background-size: 100% 3px, 6px 100%;
  pointer-events: none;
  z-index: 10;
}

.terminal-feed {
  font-family: monospace;
  font-size: 0.72rem;
  color: #a8a8a8;
  line-height: 1.5;
}

/* Breaking Headline CSS */
.term-breaking-headline {
  background: rgba(255, 46, 46, 0.03);
  border-left: 2px solid var(--color-neon-red);
