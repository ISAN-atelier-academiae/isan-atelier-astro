}

.text-gold { color: var(--color-neon-gold) !important; }
.text-green { color: var(--color-neon-green) !important; }
.text-cyan { color: var(--color-neon-cyan) !important; }

/* Article Body */
.asiento-main-article {
  padding: 2rem 1.75rem;
}

.asiento-article-title {
  font-size: 1.85rem !important;
