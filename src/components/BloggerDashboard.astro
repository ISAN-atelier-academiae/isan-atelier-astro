<style>
/* CSS Reset and Variables wrapper */
.blogger-dashboard-wrapper {
  margin-top: 3rem;
  font-family: var(--font-sans);
  color: white;
  width: 100%;
}

/* Dashboard Two-Column Grid */
.dashboard-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
}

@media (min-width: 992px) {
  .dashboard-grid {
    grid-template-columns: 7fr 3fr;
  }
}

/* Colors and Glows */
:root {
  --color-neon-gold: #fbbf24;
  --color-neon-gold-glow: rgba(251, 191, 36, 0.35);
  --color-neon-violet: #a855f7;
  --color-neon-violet-glow: rgba(168, 85, 247, 0.35);
  --color-neon-cyan: #00f2ff;
  --color-neon-cyan-glow: rgba(0, 242, 255, 0.35);
  --color-neon-red: #ff2e2e;
  --color-neon-red-glow: rgba(255, 46, 46, 0.35);
  --color-neon-green: #10b981;
}

/* Section 1: Matrix of Domains styling */
.domains-matrix-container {
  margin-bottom: 2rem;
  overflow: hidden;
}

.matrix-header {
  background: rgba(0, 242, 255, 0.08);
  border-bottom: 1px solid var(--color-glass-border);
  padding: 0.75rem 1.25rem;
  font-family: monospace;
  font-size: 0.72rem;
  font-weight: 800;
  color: var(--color-neon-cyan);
  letter-spacing: 2px;
  text-shadow: 0 0 8px var(--color-neon-cyan-glow);
}

.matrix-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1px;
  background: var(--color-glass-border);
}

@media (min-width: 576px) {
  .matrix-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

.matrix-item {
  background: rgba(10, 10, 15, 0.75);
  padding: 2.25rem 1.5rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  position: relative;
  overflow: hidden;
  text-decoration: none !important;
  transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
}

.matrix-icon {
  font-size: 2rem;
  margin-bottom: 0.75rem;
  transition: transform 0.3s;
}

.matrix-title {
  font-size: 0.95rem;
  font-weight: 800;
  letter-spacing: 1px;
  color: white;
  margin-bottom: 0.25rem;
}

.matrix-sub {
  font-size: 0.68rem;
  color: rgba(255, 255, 255, 0.45);
}

.neon-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 0%;
  height: 2px;
  transition: all 0.35s ease;
}

/* Hover behaviors for individual domains */
.matrix-item:hover {
  background: rgba(255, 255, 255, 0.02);
  transform: translateY(-2px);
}

.matrix-item:hover .matrix-icon {
  transform: scale(1.15);
}

.p-geometry:hover .matrix-title { color: var(--color-neon-gold); text-shadow: 0 0 10px var(--color-neon-gold-glow); }
.p-geometry .neon-line { background: var(--color-neon-gold); box-shadow: 0 0 8px var(--color-neon-gold); }

.p-sagrada:hover .matrix-title { color: var(--color-neon-violet); text-shadow: 0 0 10px var(--color-neon-violet-glow); }
.p-sagrada .neon-line { background: var(--color-neon-violet); box-shadow: 0 0 8px var(--color-neon-violet); }

.p-desci:hover .matrix-title { color: var(--color-neon-cyan); text-shadow: 0 0 10px var(--color-neon-cyan-glow); }
.p-desci .neon-line { background: var(--color-neon-cyan); box-shadow: 0 0 8px var(--color-neon-cyan); }

.p-auditoria:hover .matrix-title { color: var(--color-neon-red); text-shadow: 0 0 10px var(--color-neon-red-glow); }
.p-auditoria .neon-line { background: var(--color-neon-red); box-shadow: 0 0 8px var(--color-neon-red); }

.matrix-item:hover .neon-line {
  width: 70%;
}

/* Section 1.5: Sovereign Microservices Apps Styling */
.apps-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1px;
  background: var(--color-glass-border);
}

@media (min-width: 768px) {
  .apps-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

.app-item {
  background: rgba(8, 8, 12, 0.85);
  padding: 1.75rem 1.25rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
