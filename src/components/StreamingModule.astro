---
// StreamingModule.astro
// Planta 0: El Ágora (Transmisiones en Vivo)
---
<div class="streaming-agora">
  <div class="agora-header">
    <span class="live-indicator">🔴 EN VIVO</span>
    <h2>Planta 0: El Ágora</h2>
    <p>Conferencias y eventos en tiempo real de ISAN Atelier Academiae</p>
  </div>
  
  <div class="video-embed-container">
    <!-- Placeholder para iframe de YouTube / Firebase Live Stream -->
    <div class="stream-placeholder">
      <p>Esperando conexión al flujo de transmisión...</p>
      <button class="connect-stream-btn">Reconectar Cerebro</button>
    </div>
  </div>
</div>

<style>
.streaming-agora {
  border: 1px solid rgba(255, 0, 0, 0.3);
  border-radius: 12px;
  overflow: hidden;
  margin-bottom: 3rem;
  background: rgba(10, 0, 0, 0.5);
}
.agora-header {
  padding: 1.5rem;
  border-bottom: 1px solid rgba(255, 0, 0, 0.2);
}
.live-indicator {
  color: #ff4444;
  font-weight: bold;
  font-size: 0.85rem;
  letter-spacing: 1px;
  animation: pulse 2s infinite;
}
.video-embed-container {
  aspect-ratio: 16 / 9;
  background: #000;
  display: flex;
  align-items: center;
  justify-content: center;
}
.stream-placeholder {
  text-align: center;
  color: rgba(255, 255, 255, 0.5);
}
.connect-stream-btn {
  margin-top: 1rem;
  padding: 0.5rem 1rem;
  background: transparent;
  color: white;
  border: 1px solid rgba(255, 255, 255, 0.3);
  border-radius: 4px;
  cursor: pointer;
}
.connect-stream-btn:hover {
  background: rgba(255, 255, 255, 0.1);
}

@keyframes pulse {
  0% { opacity: 1; }
  50% { opacity: 0.5; }
  100% { opacity: 1; }
}
</style>
