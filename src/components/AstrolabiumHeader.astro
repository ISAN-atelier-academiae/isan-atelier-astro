---
import type { Props } from '@astrojs/starlight/props';
import Search from '@astrojs/starlight/components/Search.astro';
---
<header class="astrolabium-header flex flex-row justify-between items-center bg-black text-white px-6 py-3 border-b border-white/10 font-mono relative z-[100] transition-all duration-500">

  <!-- Estación Izquierda (Cursus) -->
  <div id="cursus-station" class="relative cursor-pointer opacity-70 hover:opacity-100 transition-all duration-300 group">
    <div id="cursus-trigger" class="text-xs tracking-widest uppercase py-2 transition-all duration-300 group-hover:text-cyan-300 group-hover:drop-shadow-[0_0_8px_rgba(34,211,238,0.8)]">
      🧭 CURSUS: NE // XII LEUCAE
    </div>
    <div id="cursus-widget" class="absolute top-full left-0 p-5 bg-[#0a0a0a]/95 border border-cyan-500/60 w-80 opacity-0 pointer-events-none transition-all duration-500 transform -translate-y-2 shadow-[0_0_25px_rgba(6,182,212,0.3)] bg-[url('https://www.transparenttextures.com/patterns/old-wall.png')]">
      <h4 class="text-[0.65rem] text-cyan-400 mb-3 border-b border-cyan-500/30 pb-1 uppercase tracking-widest text-center" style="text-shadow: 0 0 5px rgba(34,211,238,0.5);">LOGBOOK // MARES DE LEVANTE</h4>
      
      <p id="sea-tale-text" class="text-[0.7rem] leading-relaxed text-gray-300 mb-4 italic font-serif">
        Cargando relato antiguo...
      </p>

      <ul class="text-[0.65rem] space-y-1 text-[#c19a6b]/80 uppercase tracking-wider border-t border-[#c19a6b]/20 pt-3">
        <li>LAT: 45° 24' 12" N</li>
        <li>LON: 12° 20' 34" E</li>
        <li>TEMP: 285.15 K</li>
        <li>VENTUS: 12 KNOTS SE</li>
      </ul>
    </div>
  </div>

  <!-- Estación Central (Astrolabium) -->
  <div class="astrolabium-station flex-1 flex justify-center mx-4 relative">
    <!-- Overlay that darkens the background -->
    <div id="search-overlay" class="fixed inset-0 bg-black/90 backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-500" style="z-index: 90;"></div>
    
    <!-- Search Container embedding Starlight Search -->
    <div id="search-container" class="relative transition-all duration-500 w-72 hover:w-96" style="z-index: 100;">
      <Search {...Astro.props} />
    </div>
  </div>

  <!-- Estación Derecha (Status Caeli) -->
  <div id="caeli-station" class="relative cursor-pointer text-right opacity-70 hover:opacity-100 transition-all duration-300 group">
    <div id="caeli-trigger" class="text-xs tracking-widest text-emerald-400/80 uppercase py-2 transition-all duration-300 group-hover:text-emerald-300 group-hover:drop-shadow-[0_0_8px_rgba(52,211,153,0.8)]">
      🌘 LUNA CALCULANDO... // SOL IN TRANSITU
    </div>
    <!-- The Cosmic Vault Background -->
    <div id="caeli-widget" class="absolute top-full right-0 p-5 bg-black/95 border border-emerald-400/70 w-80 opacity-0 pointer-events-none transition-all duration-500 transform -translate-y-2 shadow-[0_0_30px_rgba(16,185,129,0.5)] flex flex-col items-center overflow-hidden">
      
      <!-- Bóveda del Cosmos Image Background -->
      <div class="absolute inset-0 opacity-30 bg-[url('/images/boveda_cosmos.png')] bg-cover bg-center z-0"></div>

      <div class="relative z-10 w-full flex flex-col items-center">
        <h4 class="text-[0.65rem] text-emerald-400/90 mb-3 border-b border-emerald-500/50 pb-1 w-full text-center tracking-widest font-bold drop-shadow-[0_0_5px_rgba(16,185,129,0.8)]">BÓVEDA DEL COSMOS</h4>
        
        <!-- Interactive SVG Astrolabe -->
        <div class="relative w-24 h-24 mb-3 drop-shadow-[0_0_10px_rgba(16,185,129,0.5)]">
          <svg id="astrolabe-svg" viewBox="0 0 100 100" class="text-emerald-400 absolute inset-0 w-full h-full animate-[spin_120s_linear_infinite]">
            <circle cx="50" cy="50" r="48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-dasharray="2 4" />
            <circle cx="50" cy="50" r="40" fill="none" stroke="currentColor" stroke-width="0.5" />
            <circle cx="50" cy="50" r="30" fill="none" stroke="currentColor" stroke-width="0.2" stroke-dasharray="1 2" />
            <path d="M 50 2 L 50 98 M 2 50 L 98 50" stroke="currentColor" stroke-width="0.5" opacity="0.6" />
            <path d="M 16 16 L 84 84 M 16 84 L 84 16" stroke="currentColor" stroke-width="0.2" opacity="0.4" />
          </svg>
          <svg id="moon-orbit-svg" viewBox="0 0 100 100" class="absolute inset-0 w-full h-full text-cyan-300">
            <!-- The moon will be positioned via JS based on phase -->
            <circle id="moon-svg-circle" cx="50" cy="10" r="4" fill="currentColor" class="transition-all duration-1000 drop-shadow-[0_0_8px_rgba(0,255,255,0.8)]" />
            <circle cx="50" cy="50" r="2" fill="currentColor" class="text-emerald-200" /> <!-- Earth/Center -->
          </svg>
        </div>
        
        <div id="caeli-details" class="mt-1 text-[0.65rem] text-emerald-200 text-center tracking-widest whitespace-pre-line leading-relaxed font-bold drop-shadow-md">
          CALIBRANDO ORBITAS...
        </div>

        <div id="astronomical-event" class="mt-2 text-[0.6rem] text-cyan-400/90 text-center tracking-widest uppercase border-t border-emerald-500/30 pt-2 w-full">
          EVENTO ASTRONÓMICO...
        </div>

        <p id="cosmic-tale-text" class="mt-3 text-[0.65rem] leading-relaxed text-gray-200 italic font-serif text-center bg-black/60 p-2 rounded border border-emerald-500/20">
          Sintonizando ecos del universo...
        </p>
      </div>
    </div>
  </div>

  </div>

  <!-- Modal Ampliado (Enlaces de Trabajo) -->
  <div id="astrolabium-modal" class="fixed inset-0 bg-black/95 backdrop-blur-sm opacity-0 pointer-events-none transition-all duration-500 flex items-center justify-center z-[1000]">
    <div class="relative w-full max-w-3xl bg-[#050505] border border-cyan-500/60 p-10 shadow-[0_0_50px_rgba(0,242,255,0.15)] rounded-sm transform scale-95 transition-transform duration-500" id="astrolabium-modal-content">
      <button id="close-modal-btn" class="absolute top-4 right-5 text-gray-500 hover:text-cyan-400 hover:drop-shadow-[0_0_5px_rgba(0,242,255,0.8)] transition-all text-2xl leading-none">&times;</button>
      
      <h3 class="text-2xl font-mono text-cyan-400 tracking-widest mb-8 border-b border-cyan-500/30 pb-3 uppercase text-center drop-shadow-[0_0_8px_rgba(0,242,255,0.5)]">
        BITÁCORA EXTENDIDA & CONEXIONES
      </h3>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 font-mono text-sm">
        <div class="p-4 border border-emerald-500/20 bg-emerald-900/10">
          <h4 class="text-emerald-400 mb-5 tracking-wider border-b border-emerald-500/20 pb-2 drop-shadow-[0_0_5px_rgba(16,185,129,0.5)]">PORTAFOLIO ACADÉMICO</h4>
          <ul class="space-y-4 text-gray-300">
            <li><a href="#" class="hover:text-emerald-300 hover:drop-shadow-[0_0_5px_rgba(16,185,129,0.5)] transition-all flex items-center gap-2"><span class="text-emerald-500/50">></span> Investigación Arquitectónica</a></li>
            <li><a href="#" class="hover:text-emerald-300 hover:drop-shadow-[0_0_5px_rgba(16,185,129,0.5)] transition-all flex items-center gap-2"><span class="text-emerald-500/50">></span> Tratados Herméticos</a></li>
            <li><a href="#" class="hover:text-emerald-300 hover:drop-shadow-[0_0_5px_rgba(16,185,129,0.5)] transition-all flex items-center gap-2"><span class="text-emerald-500/50">></span> Metrología de Giza</a></li>
          </ul>
        </div>
        <div class="p-4 border border-cyan-500/20 bg-cyan-900/10">
          <h4 class="text-cyan-400 mb-5 tracking-wider border-b border-cyan-500/20 pb-2 drop-shadow-[0_0_5px_rgba(0,242,255,0.5)]">RUTAS EXTERNAS</h4>
          <ul class="space-y-4 text-gray-300">
            <li><a href="#" class="hover:text-cyan-300 hover:drop-shadow-[0_0_5px_rgba(0,242,255,0.5)] transition-all flex items-center gap-2"><span class="text-cyan-500/50">></span> Bitácoras del Siglo XXI</a></li>
            <li><a href="#" class="hover:text-cyan-300 hover:drop-shadow-[0_0_5px_rgba(0,242,255,0.5)] transition-all flex items-center gap-2"><span class="text-cyan-500/50">></span> Modelos 3D (Bóveda)</a></li>
            <li><a href="#" class="hover:text-cyan-300 hover:drop-shadow-[0_0_5px_rgba(0,242,255,0.5)] transition-all flex items-center gap-2"><span class="text-cyan-500/50">></span> Contacto Corsario</a></li>
          </ul>
        </div>
      </div>
      
      <div class="mt-8 pt-4 border-t border-white/10 text-center text-xs text-gray-500 italic font-serif">
        "Las llaves del cosmos se encuentran en los nodos que conectamos."
      </div>
    </div>
  </div>

</header>

<style>
/* CSS overrides for Starlight Search inside Astrolabium */
:global(.astrolabium-header site-search) {
  display: block;
  width: 100%;
}

/* Neon glow and star background for the main search button ONLY */
:global(.astrolabium-header site-search button[data-open-modal]) {
  width: 100%;
  background: radial-gradient(circle at center, rgba(0, 242, 255, 0.05) 0%, transparent 70%) !important;
  border: 1px solid rgba(0, 242, 255, 0.4) !important;
  border-radius: 4px !important;
  color: rgba(0, 242, 255, 0.8) !important;
  padding: 0.5rem 1rem !important;
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace !important;
  font-size: 0.8rem !important;
  letter-spacing: 1px;
  justify-content: space-between !important;
  transition: all 0.4s ease;
  box-shadow: 0 0 15px rgba(0, 242, 255, 0.1), inset 0 0 10px rgba(0, 242, 255, 0.05) !important;
  position: relative;
  overflow: hidden;
  display: flex !important;
  align-items: center;
}

:global(.astrolabium-header site-search button[data-open-modal]:hover) {
  border-color: rgba(0, 242, 255, 0.8) !important;
  background: rgba(0, 242, 255, 0.1) !important;
  color: #fff !important;
  box-shadow: 0 0 25px rgba(0, 242, 255, 0.4), inset 0 0 15px rgba(0, 242, 255, 0.2) !important;
  transform: scale(1.02);
}

/* Override the text inside the search button using pseudo-elements */
:global(.astrolabium-header site-search button[data-open-modal] .sl-icon) {
  display: none !important; /* Hide default icon */
}

/* Add the Custom Text and CTRL + K */
:global(.astrolabium-header site-search button[data-open-modal]::before) {
  content: '🔍 Caelum inspicere...';
  display: inline-block;
  text-shadow: 0 0 5px rgba(0,242,255,0.5);
}

:global(.astrolabium-header site-search button[data-open-modal] > span) {
  display: none !important;
}
:global(.astrolabium-header site-search button[data-open-modal] > kbd) {
  display: none !important;
}

/* Add CTRL + K Badge at the end of the button */
:global(.astrolabium-header site-search button[data-open-modal])::after {
  content: 'CTRL + K';
  position: relative;
  background: rgba(0, 242, 255, 0.1);
  border: 1px solid rgba(0, 242, 255, 0.3);
  padding: 0.1rem 0.4rem;
  border-radius: 3px;
  font-size: 0.65rem;
  color: rgba(0, 242, 255, 0.9);
  margin-left: auto;
}

/* Starlight's modal container adjustments */
:global(site-search dialog) {
  z-index: 1000 !important;
}

/* Alchemical Watermark inside the search modal */
:global(site-search .dialog-frame::before) {
  content: '🜁 🜂 🜃 🜄';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 4rem;
  color: rgba(0, 242, 255, 0.15) !important; /* Made it slightly more visible */
  pointer-events: none;
  z-index: 0;
  letter-spacing: 2rem;
  width: 100%;
  text-align: center;
  text-shadow: 0 0 20px rgba(0, 242, 255, 0.4); /* Stronger glow */
  font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif;
}

/* Bring the search input to the front */
:global(#starlight__search) {
  position: relative;
  z-index: 10;
}

/* Neon glow for ESC button and Clear button inside the modal */
:global(site-search button[data-close-modal]),
:global(#starlight__search .pagefind-ui__search-clear) {
  background: rgba(0, 242, 255, 0.05) !important;
  border: 1px solid rgba(0, 242, 255, 0.4) !important;
  border-radius: 4px !important;
  color: rgba(0, 242, 255, 0.8) !important;
  box-shadow: 0 0 10px rgba(0, 242, 255, 0.1), inset 0 0 5px rgba(0, 242, 255, 0.05) !important;
  transition: all 0.3s ease !important;
  cursor: pointer !important;
  z-index: 9999 !important;
  pointer-events: auto !important;
  display: flex !important;
  align-items: center;
  justify-content: center;
  padding: 0.2rem 0.6rem !important;
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace !important;
  font-size: 0.75rem !important;
}

:global(site-search button[data-close-modal]:hover),
:global(#starlight__search .pagefind-ui__search-clear:hover) {
  background: rgba(0, 242, 255, 0.2) !important;
  border-color: rgba(0, 242, 255, 0.8) !important;
  color: #fff !important;
  box-shadow: 0 0 20px rgba(0, 242, 255, 0.4), inset 0 0 10px rgba(0, 242, 255, 0.2) !important;
  transform: scale(1.05) !important;
}

/* Lupa (Magnifying glass) inside the modal */
:global(#starlight__search .pagefind-ui__form::before) {
  background-color: rgba(0, 242, 255, 0.8) !important;
  filter: drop-shadow(0 0 5px rgba(0, 242, 255, 0.8)) !important;
  cursor: pointer !important;
  transition: all 0.3s ease !important;
  pointer-events: auto !important;
  z-index: 100 !important;
}

:global(#starlight__search .pagefind-ui__form::before:hover) {
  background-color: #fff !important;
  filter: drop-shadow(0 0 12px rgba(0, 242, 255, 1)) !important;
  transform: scale(1.1) !important;
}

/* Make sure the input field itself looks good with the neon theme */
:global(#starlight__search .pagefind-ui__search-input) {
  border: 1px solid rgba(0, 242, 255, 0.3) !important;
  border-radius: 4px !important;
  background: rgba(0, 0, 0, 0.5) !important;
  color: rgba(0, 242, 255, 0.9) !important;
  box-shadow: inset 0 0 10px rgba(0, 242, 255, 0.05) !important;
  transition: all 0.3s ease !important;
}

:global(#starlight__search .pagefind-ui__search-input:focus) {
  border-color: rgba(0, 242, 255, 0.8) !important;
  box-shadow: 0 0 15px rgba(0, 242, 255, 0.2), inset 0 0 10px rgba(0, 242, 255, 0.1) !important;
  outline: none !important;
}
</style>

<script>
import { getWeeklyData, getAstronomicalEvents } from '../utils/astrolabiumData';

// --- Hover Logic Implementation ---
const cursusStation = document.getElementById('cursus-station');
const cursusWidget = document.getElementById('cursus-widget');

if (cursusStation && cursusWidget) {
  cursusStation.addEventListener('mouseenter', () => {
    cursusWidget.classList.remove('opacity-0', 'pointer-events-none', '-translate-y-2');
    cursusWidget.classList.add('opacity-100', 'pointer-events-auto', 'translate-y-0');
  });
  cursusStation.addEventListener('mouseleave', () => {
    cursusWidget.classList.add('opacity-0', 'pointer-events-none', '-translate-y-2');
    cursusWidget.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
  });
}

const caeliStation = document.getElementById('caeli-station');
const caeliWidget = document.getElementById('caeli-widget');

if (caeliStation && caeliWidget) {
  caeliStation.addEventListener('mouseenter', () => {
    caeliWidget.classList.remove('opacity-0', 'pointer-events-none', '-translate-y-2');
    caeliWidget.classList.add('opacity-100', 'pointer-events-auto', 'translate-y-0');
  });
  caeliStation.addEventListener('mouseleave', () => {
    caeliWidget.classList.add('opacity-0', 'pointer-events-none', '-translate-y-2');
    caeliWidget.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
  });
}

// --- Modal Ampliado Logic ---
const modal = document.getElementById('astrolabium-modal');
const modalContent = document.getElementById('astrolabium-modal-content');
const closeBtn = document.getElementById('close-modal-btn');

function openModal() {
  if (modal && modalContent) {
    modal.classList.remove('opacity-0', 'pointer-events-none');
    modal.classList.add('opacity-100', 'pointer-events-auto');
    modalContent.classList.remove('scale-95');
    modalContent.classList.add('scale-100');
  }
}

function closeModal() {
  if (modal && modalContent) {
    modal.classList.add('opacity-0', 'pointer-events-none');
    modal.classList.remove('opacity-100', 'pointer-events-auto');
    modalContent.classList.remove('scale-100');
    modalContent.classList.add('scale-95');
  }
}

if (cursusStation) cursusStation.addEventListener('click', openModal);
if (caeliStation) caeliStation.addEventListener('click', openModal);
if (closeBtn) closeBtn.addEventListener('click', (e) => { e.stopPropagation(); closeModal(); });
if (modal) modal.addEventListener('click', (e) => {
  if (e.target === modal) closeModal();
});


// --- Estación Central (Astrolabium) Search Overlay Logic ---
const searchOverlay = document.getElementById('search-overlay');
const observer = new MutationObserver((mutations) => {
  mutations.forEach((mutation) => {
    if (mutation.type === 'attributes' && mutation.attributeName === 'open') {
      const dialog = document.querySelector('dialog[open]');
      if (dialog && searchOverlay) {
        searchOverlay.classList.remove('opacity-0', 'pointer-events-none');
        searchOverlay.classList.add('opacity-100', 'pointer-events-auto');
      } else if (searchOverlay) {
        searchOverlay.classList.add('opacity-0', 'pointer-events-none');
        searchOverlay.classList.remove('opacity-100', 'pointer-events-auto');
      }
    }
  });
});
observer.observe(document.body, { attributes: true, subtree: true, attributeFilter: ['open'] });

// Close overlay when dialog is closed (Starlight handles Escape key internally)
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape' && searchOverlay) {
    searchOverlay.classList.add('opacity-0', 'pointer-events-none');
    searchOverlay.classList.remove('opacity-100', 'pointer-events-auto');
  }
});


// --- Cosmic Math & Data Population ---
const caeliTrigger = document.getElementById('caeli-trigger');
const caeliDetails = document.getElementById('caeli-details');
const moonSvgCircle = document.getElementById('moon-svg-circle');
const astroEventText = document.getElementById('astronomical-event');
const seaTaleText = document.getElementById('sea-tale-text');
const cosmicTaleText = document.getElementById('cosmic-tale-text');

// Lunar Phase Calculation
function getMoonPhase(date: Date) {
  let year = date.getFullYear();
  let month = date.getMonth() + 1;
  let day = date.getDate();
  if (month < 3) { year--; month += 12; }
  ++month;
  let c = 365.25 * year;
  let e = 30.6 * month;
  let jd = c + e + day - 694039.09; // julian days
  jd /= 29.5305882; // cycle
  let b = Math.floor(jd); // fractional
  jd -= b;
  let b2 = Math.round(jd * 8); // 8 phases
  if (b2 >= 8) b2 = 0; 
  return { phaseFraction: jd, phaseIndex: b2 };
}

const moonPhases = [
  "NOVA", "CRESCENS", "SECTIO I", "GIBBOSA", 
  "PLENA", "GIBBOSA DECRESCENS", "SECTIO III", "DECRESCENS"
];

const constellations = [
  "CAPRICORNUS", "AQUARIUS", "PISCES", "ARIES", 
  "TAURUS", "GEMINI", "CANCER", "LEO", 
  "VIRGO", "LIBRA", "SCORPIUS", "SAGITTARIUS"
];

function updateAstrolabe() {
  const now = new Date();
  const moon = getMoonPhase(now);
  const month = now.getMonth();
  
  if (caeliTrigger) {
    caeliTrigger.innerText = `🌘 LUNA ${moonPhases[moon.phaseIndex]} // SOL IN ${constellations[month]}`;
  }
  
  if (caeliDetails) {
    const illum = Math.round((0.5 - Math.cos(moon.phaseFraction * Math.PI * 2) / 2) * 100);
    caeliDetails.innerText = `ILLUMINATIO: ${illum}%\nPHASIS: ${moon.phaseFraction.toFixed(4)}\nCONST: ${constellations[month]}`;
  }
  
  // Position moon circle based on phase (orbiting the center)
  if (moonSvgCircle) {
    const angle = moon.phaseFraction * Math.PI * 2 - (Math.PI / 2); // Start at top
    const radius = 40;
    const cx = 50 + radius * Math.cos(angle);
    const cy = 50 + radius * Math.sin(angle);
    moonSvgCircle.setAttribute('cx', cx.toString());
    moonSvgCircle.setAttribute('cy', cy.toString());
    
    // Adjust moon size based on illumination
    const illum = 0.5 - Math.cos(moon.phaseFraction * Math.PI * 2) / 2;
    const r = 2 + (illum * 4); // Radius between 2 and 6
    moonSvgCircle.setAttribute('r', r.toString());
  }

  // Populate Astronomical Event
  if (astroEventText) {
    const astroData = getAstronomicalEvents(now);
    astroEventText.innerText = `PRÓXIMO: ${astroData.nextEvent} (T-${astroData.daysUntil} DÍAS)`;
  }

  // Populate Myths
  const weeklyData = getWeeklyData();
  if (seaTaleText) {
    seaTaleText.innerText = weeklyData.seaTale;
  }
  if (cosmicTaleText) {
    cosmicTaleText.innerText = weeklyData.cosmicTale;
  }
}

// Initial Call
updateAstrolabe();
</script>
