---
// VisitorComments.astro
// Integración de Giscus para la interacción de investigadores en el Campus
---
<div class="comments-section">
  <h3>Análisis y Anotaciones de la Comunidad</h3>
  <script src="https://giscus.app/client.js"
          data-repo="ISAN-Academia/isan-atelier-astro"
          data-repo-id="R_kgDOM_xxxx"
          data-category="Análisis Científico"
          data-category-id="DIC_kwDOM_xxxx"
          data-mapping="pathname"
          data-strict="0"
          data-reactions-enabled="1"
          data-emit-metadata="0"
          data-input-position="bottom"
          data-theme="transparent_dark"
          data-lang="es"
          crossorigin="anonymous"
          async>
  </script>
</div>

<style>
.comments-section {
  margin-top: 4rem;
  padding-top: 2rem;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  font-family: var(--font-sans);
}
</style>
