  <!-- Selectores de Módulo (Tabs) -->
  <div class="dashboard-tabs">
    <button class="db-tab-btn active" onclick="switchDbTab('db-catalogo')">🏺 CATÁLOGO SELLO QR</button>
    <button class="db-tab-btn" onclick="switchDbTab('db-fichas')">🧘 FICHAS METODOLÓGICAS</button>
