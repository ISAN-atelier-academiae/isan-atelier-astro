        <div class="pub-hash-container">
          <span class="hash-label">SHA-256:</span>
          <code class="pub-hash" title="c28d716cf9ef673196f7c6e61f215e98516ee71a7d65691e847c1ba0c18d18e77a">c28d716c...77a</code>
        </div>
        <div class="pub-actions">
