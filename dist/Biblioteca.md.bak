        <rect x="45" y="60" width="8" height="8" fill="currentColor" />
        <rect x="60" y="60" width="8" height="8" fill="currentColor" />
        <rect x="75" y="75" width="8" height="8" fill="currentColor" />
        <rect x="60" y="75" width="8" height="8" fill="currentColor" />
        <rect x="45" y="75" width="8" height="8" fill="currentColor" />
      </svg>
    </div>
    <p class="qr-help-text">Escanea este código con tu dispositivo móvil para acceder al documento oficial.</p>
    <button class="pub-btn" onclick="closeQrModal()">CERRAR ENLACE AXIAL</button>
  </div>
</div>

<style>
/* Dashboard Estilos Súper Premium */
.biblioteca-dashboard {
