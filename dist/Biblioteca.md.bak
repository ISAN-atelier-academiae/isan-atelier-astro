<!-- Lógica de Funcionamiento del Dashboard -->
<script type="application/javascript">
  // Registro de base de datos de firmas autoritativas
  const dbAuthHashes = {
    "c92d716cf9ef673196f7c6e61f215e98516ee71a7d65691e847c1ba0c18d18e1fa": "Biblioteca Alejandrina",
    "c28d716cf9ef673196f7c6e61f215e98516ee71a7d65691e847c1ba0c18d18e77a": "Ley de la Convergencia",
    "468d716cf9ef673196f7c6e61f215e98516ee71a7d65691e847c1ba0c18d18f50c": "Sendero de la Serpiente",
    "b71d716cf9ef673196f7c6e61f215e98516ee71a7d65691e847c1ba0c18d18e20b": "Anales Académicos",
    "d48d716cf9ef673196f7c6e61f215e98516ee71a7d65691e847c1ba0c18d18e31a": "Curia Cambii (Tabla)",
    "e12d716cf9ef673196f7c6e61f215e98516ee71a7d65691e847c1ba0c18d18e47f": "Codex Vitruvianus",
    "a84d716cf9ef673196f7c6e61f215e98516ee71a7d65691e847c1ba0c18d18e5b2": "Escudo del Atelier",
    "f32d716cf9ef673196f7c6e61f215e98516ee71a7d65691e847c1ba0c18d18e69d": "Mysterium Web (Cursos)",
    "012d716cf9ef673196f7c6e61f215e98516ee71a7d65691e847c1ba0c18d18e80a": "Clave del Búnker",
    "b21d716cf9ef673196f7c6e61f215e98516ee71a7d65691e847c1ba0c18d18f9d0": "Tablas del Manifiesto"
  };

  // Switchear de Tab
  window.switchDbTab = function(tabId) {
    // Esconder todos los contenidos
    const contents = document.querySelectorAll('.db-tab-content');
    contents.forEach(content => content.classList.remove('active'));

    // Desactivar todos los botones
    const buttons = document.querySelectorAll('.db-tab-btn');
    buttons.forEach(btn => btn.classList.remove('active'));

    // Activar los correctos
    const targetContent = document.getElementById(tabId);
    if(targetContent) targetContent.classList.add('active');

    // Activar el botón correspondiente
    const activeBtn = Array.from(buttons).find(btn => btn.getAttribute('onclick').includes(tabId));
    if(activeBtn) activeBtn.classList.add('active');
  };

  // Modal QR
  window.showQrModal = function(title, url) {
    const modal = document.getElementById('qr-modal');
    const modalTitle = document.getElementById('qr-modal-title');
    if (modal && modalTitle) {
      modalTitle.innerText = `Sello QR: ${title}`;
      modal.style.display = 'flex';
    }
  };

  window.closeQrModal = function() {
    const modal = document.getElementById('qr-modal');
    if (modal) modal.style.display = 'none';
  };

  // Configuración del Validador Criptográfico Drag & Drop
  const dropZone = document.getElementById('crypto-drop-zone');
  const fileInput = document.getElementById('dz-file-input');
  const resultsBox = document.getElementById('validator-results');

  if (dropZone && fileInput && resultsBox) {
    // Abrir buscador al clickear zona
    dropZone.addEventListener('click', () => fileInput.click());

    fileInput.addEventListener('change', (e) => {
      const file = e.target.files[0];
      if (file) processFileForVerification(file);
    });

    // Drag-over styling
    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropZone.classList.add('dragover');
    });

    dropZone.addEventListener('dragleave', () => {
      dropZone.classList.remove('dragover');
    });

    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZone.classList.remove('dragover');
      const file = e.dataTransfer.files[0];
      if (file) processFileForVerification(file);
    });
  }

  function processFileForVerification(file) {
    resultsBox.style.display = 'block';
    
    const statusBox = document.getElementById('result-status-box');
    const statusTitle = document.getElementById('result-status-title');
    const statusDesc = document.getElementById('result-status-desc');
    const fileName = document.getElementById('meta-file-name');
    const fileHash = document.getElementById('meta-file-hash');

    // Update initial view
    statusBox.className = 'result-status-box';
    statusTitle.innerText = 'CALCULANDO HASH...';
    statusDesc.innerText = 'Calculando firma criptográfica SHA-256 local-first...';
    fileName.innerText = file.name;
    fileHash.innerText = 'Calculando...';

    // Leer archivo y computar digest SHA-256 local
    const reader = new FileReader();
    reader.onload = async function(e) {
      try {
        const arrayBuffer = e.target.result;
        
        // Cómputo nativo súper rápido de Web Crypto API
        const hashBuffer = await crypto.subtle.digest('SHA-256', arrayBuffer);
        const hashArray = Array.from(new Uint8Array(hashBuffer));
        const hashHex = hashArray.map(b => b.toString(16).padStart(2, '0')).join('');

        fileHash.innerText = hashHex;

        // Comprobar contra base de datos
        if (dbAuthHashes[hashHex]) {
          statusBox.classList.add('valid');
          statusTitle.innerText = '✔ DOCUMENTO SOBERANO AUTÉNTICO';
          statusDesc.innerText = `Firma verificada exitosamente: "${dbAuthHashes[hashHex]}" (Estatus publicable aprobado por ISAN-2026).`;
        } else {
          statusBox.classList.add('invalid');
          statusTitle.innerText = '⚠ FIRMA DESCONOCIDA / ALTERACIÓN';
          statusDesc.innerText = 'El hash computado localmente no coincide con ningún documento registrado en el catálogo público oficial.';
        }
      } catch (err) {
        statusTitle.innerText = 'ERROR EN PROCESAMIENTO';
        statusDesc.innerText = 'No se pudo calcular el hash criptográfico del archivo local.';
      }
    };
    reader.readAsArrayBuffer(file);
  }
</script>

